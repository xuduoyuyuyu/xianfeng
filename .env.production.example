# Docker Compose project name
COMPOSE_PROJECT_NAME=xianfeng

# Public app settings
PORT=3001
CORS_ORIGIN=https://your-domain.com
ALLOW_PUBLIC_REGISTER=false

# Frontend build setting
# Leave empty when frontend and API share the same domain through Nginx gateway.
VITE_API_URL=

# Database
MONGO_PORT=27017
MONGODB_URI=mongodb://mongo:27017/knowledge-base

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# AI generation
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
AI_TEXT_MODEL=gpt-4o-mini

# Volcengine speech-to-text
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=
VOLCENGINE_API_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_RESOURCE_ID=volc.bigasr.auc_turbo,volc.bigasr.auc
VOLCENGINE_MODE=flash

# Volcengine ARK (metadata extraction)
ARK_API_KEY=
ARK_MODEL_ID=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
