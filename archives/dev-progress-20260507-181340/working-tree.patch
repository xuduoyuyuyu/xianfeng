+
+      const deviceBreakdown = [
+        { label: "PC", count: deviceMap.desktop || 0 },
+        { label: "移动端", count: (deviceMap.mobile || 0) + (deviceMap.tablet || 0) },
+        { label: "其他", count: (deviceMap.other || 0) + (deviceMap.bot || 0) },
