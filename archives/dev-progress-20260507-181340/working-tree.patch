+  if (type.includes("jpeg") || type.includes("jpg")) return ".jpg";
+  const pathname = fallbackUrl ? new URL(fallbackUrl).pathname : "";
+  const ext = path.extname(pathname).toLowerCase();
+  return ext || ".png";
