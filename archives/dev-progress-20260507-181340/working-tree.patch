+    asText(taskConfig.promptDoc?.system_prompt) ||
+    "你是嘉宾资料收集助手，只输出严格 JSON，不要输出解释文字。";
+  try {
+    const upstream = await fetch(endpoint, {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
