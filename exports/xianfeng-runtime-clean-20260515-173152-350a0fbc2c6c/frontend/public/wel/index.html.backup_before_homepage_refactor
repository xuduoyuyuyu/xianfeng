async function saveProfileEditor(){
  const btn = $id('p-save');
  const old = btn.textContent;
  btn.disabled = true; btn.textContent = '保存中...';
  try{
    const payload = {
      name: ($id('p-name').value || '').trim(),
      city: ($id('p-city').value || '').trim(),
      grade: ($id('p-grade').value || '').trim(),
      avatar_initial: (($id('p-name').value || '').trim()[0] || ME.avatar_initial || '探'),
