  if (old) old.remove();
  const box = document.createElement('div');
  box.id = '__wrong_import_modal';
  box.style.cssText = 'position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;';
  box.innerHTML = `
    <div data-wim-mask style="position:absolute;inset:0;background:rgba(17,24,39,.36);backdrop-filter:blur(7px);"></div>
    <div style="position:relative;width:min(760px,92vw);height:min(620px,86vh);background:#fff;border-radius:22px;box-shadow:0 24px 72px rgba(15,23,42,.28);overflow:hidden;border:1px solid #e5e7eb;">
      <button data-wim-close style="position:absolute;top:12px;right:12px;width:36px;height:36px;border-radius:10px;border:1px solid #e5e7eb;background:#fff;color:#64748b;font-size:18px;line-height:1;cursor:pointer;z-index:2;">×</button>
      <iframe data-wim-frame src="pages/09 错题入库/code.html" style="width:100%;height:100%;border:0;background:#fff;"></iframe>
    </div>
  `;
  document.body.appendChild(box);
  const close = () => box.remove();
  const mask = box.querySelector('[data-wim-mask]');
  const closeBtn = box.querySelector('[data-wim-close]');
  const frame = box.querySelector('[data-wim-frame]');
  if (mask) mask.onclick = close;
  if (closeBtn) closeBtn.onclick = close;
  if (frame) frame.onload = () => {
    try{
      const w = frame.contentWindow;
      const doc = w.document;
      const doImport = async (btnText='导入') => {
        let question = '';
        doc.querySelectorAll('textarea,input[type="text"]').forEach(inp => {
          const v = String(inp.value || '').trim();
          if (v.length > 5) question = v;
        });
        if (!question) question = `（${btnText}）请补充题目内容后可继续完善归因`;
        const r = await api('POST','/api/wrongs',{question,subject:'数学',source:'手动录入'});
        curWrongId = r.id;
        close();
        toast('错题已录入，进入归因诊断');
        go(19);
      };
      doc.querySelectorAll('button').forEach(btn => {
        const t = String(btn.textContent || '').trim();
        if (t.includes('批量拍照') || t.includes('选择本地文件') || t.includes('上传')) {
          btn.onclick = async (e) => {
            e.preventDefault();
            try { await doImport(t); } catch(err){ toast(err.message || '录入失败','err'); }
          };
        }
      });
    }catch(e){ console.warn('wrong import modal bind', e); }
  };
}

