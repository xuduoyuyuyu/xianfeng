        if (!weakRows.length) ctx.fillText('暂无薄弱项数据', 90, y);
        ctx.fillStyle = '#94a3b8';
        ctx.font = '500 20px "Noto Sans SC","PingFang SC","Microsoft YaHei",sans-serif';
        ctx.fillText(`导出时间：${new Date().toLocaleString()}`, 70, 1708);
        const jpgData = canvas.toDataURL('image/jpeg', 0.92).split(',')[1] || '';
        const jpgBytes = Uint8Array.from(atob(jpgData), c => c.charCodeAt(0));
        const contentStream = `q\n595 0 0 842 0 0 cm\n/Im0 Do\nQ\n`;
        const o1 = `1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n`;
        const o2 = `2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n`;
        const o3 = `3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Resources << /XObject << /Im0 4 0 R >> >> /Contents 5 0 R >>\nendobj\n`;
        const o4h = `4 0 obj\n<< /Type /XObject /Subtype /Image /Width ${canvas.width} /Height ${canvas.height} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${jpgBytes.length} >>\nstream\n`;
        const o4t = `\nendstream\nendobj\n`;
        const o5 = `5 0 obj\n<< /Length ${contentStream.length} >>\nstream\n${contentStream}endstream\nendobj\n`;
        const head = `%PDF-1.4\n`;
        const enc = new TextEncoder();
        const pHead = enc.encode(head), p1 = enc.encode(o1), p2 = enc.encode(o2), p3 = enc.encode(o3), p4h = enc.encode(o4h), p4t = enc.encode(o4t), p5 = enc.encode(o5);
        const off1 = pHead.length;
        const off2 = off1 + p1.length;
        const off3 = off2 + p2.length;
        const off4 = off3 + p3.length;
        const off5 = off4 + p4h.length + jpgBytes.length + p4t.length;
        const xrefStart = off5 + p5.length;
        const pad = n => String(n).padStart(10, '0');
        const xref = `xref\n0 6\n0000000000 65535 f \n${pad(off1)} 00000 n \n${pad(off2)} 00000 n \n${pad(off3)} 00000 n \n${pad(off4)} 00000 n \n${pad(off5)} 00000 n \ntrailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n${xrefStart}\n%%EOF`;
        const pX = enc.encode(xref);
        const pdf = new Uint8Array(xrefStart + pX.length);
        let ptr = 0;
        pdf.set(pHead, ptr); ptr += pHead.length;
        pdf.set(p1, ptr); ptr += p1.length;
        pdf.set(p2, ptr); ptr += p2.length;
        pdf.set(p3, ptr); ptr += p3.length;
        pdf.set(p4h, ptr); ptr += p4h.length;
        pdf.set(jpgBytes, ptr); ptr += jpgBytes.length;
        pdf.set(p4t, ptr); ptr += p4t.length;
        pdf.set(p5, ptr); ptr += p5.length;
        pdf.set(pX, ptr);
