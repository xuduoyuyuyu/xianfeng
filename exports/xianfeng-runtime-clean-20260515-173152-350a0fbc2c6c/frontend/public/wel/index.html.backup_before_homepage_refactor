function showFrame(id, path, extra={}) {
  const area=$id('farea'), lb=$id('lbar');
  
  // Construct query string
  const qs = Object.entries(extra).map(([k,v]) => `${k}=${encodeURIComponent(v)}`).join('&');
  const url = path + '?t=' + new Date().getTime() + (qs ? '&' + qs : '');

  Object.values(FR).forEach(f=>f.classList.remove('on'));
  
  // Special case: Always reload detail pages to apply new params
  if ((id === 21 || id === 34 || id === 52 || (id === 1 && (extra.tid || extra.title))) && FR[id]) {
    FR[id].remove();
    delete FR[id];
  }

  if (FR[id]) {
    FR[id].classList.add('on');
    bridgePage(id, FR[id], extra);
    return;
  }
  lb.classList.add('on');
  const f=document.createElement('iframe'); f.className='pf'; 
  f.src=url;
  f.onload=()=>{ 
    lb.classList.remove('on'); 
    injectCSS(f); 
    bridgePage(id,f,extra); 
    f.classList.add('on');
  };
  area.appendChild(f); FR[id]=f;
}

function injectCSS(iframe) {
  try {
    const doc=iframe.contentDocument||iframe.contentWindow.document;
    if (!doc.getElementById('__wel')) doc.head.insertAdjacentHTML('beforeend', HIDE_NAV);
  } catch(e){}
}

