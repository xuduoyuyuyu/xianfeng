function decodeHtmlText(raw='') {
  const t = document.createElement('textarea');
  t.innerHTML = String(raw || '');
  return t.value || '';
}

function sanitizeRichMathHtml(raw='') {
  const src = decodeHtmlText(String(raw || ''));
  const tpl = document.createElement('template');
  tpl.innerHTML = src;
  const blocked = new Set(['script','style','iframe','object','embed','link','meta']);
  const walk = (node) => {
    if (node.nodeType === 1) {
      const tag = String(node.tagName || '').toLowerCase();
      if (blocked.has(tag)) { node.remove(); return; }
      [...node.attributes].forEach(attr => {
        const n = String(attr.name || '').toLowerCase();
        const v = String(attr.value || '');
        if (n.startsWith('on') || n === 'srcdoc') node.removeAttribute(attr.name);
        if ((n === 'href' || n === 'src') && /^javascript:/i.test(v)) node.removeAttribute(attr.name);
      });
    }
    [...node.childNodes].forEach(walk);
  };
  walk(tpl.content);
  return tpl.innerHTML;
}

function hasMathLikeContent(v='') {
  const s = String(v || '');
  return /<\s*math[\s>]|&lt;\s*math|\\\(|\\\[|\$\$|\$[^$]+\$|<\s*mrow[\s>]/i.test(s);
}

function escapeHtmlText(s='') {
  return String(s || '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

function formatEnumeratedTextHtml(v='') {
  const text = String(v || '').trim();
  if (!text) return '';
  const markRegex = /(①|②|③|④|⑤|⑥|⑦|⑧|⑨|⑩|⑪|⑫)/g;
  const marks = text.match(markRegex) || [];
  let out = text;
  if (marks.length >= 2) {
    out = out.replace(markRegex, '\n$1').replace(/^\n+/, '');
    out = out.replace(/[；;]\s*\n/g, '\n');
    return escapeHtmlText(out).replace(/\n+/g, '<br>');
  }
  if (/([；;]\s*)(?=(\d+\s*[\.、\)]|[A-D]\s*[\.、\)]))/i.test(text)) {
    out = text.replace(/([；;]\s*)(?=(\d+\s*[\.、\)]|[A-D]\s*[\.、\)]))/ig, '$1\n');
    return escapeHtmlText(out).replace(/\n+/g, '<br>');
  }
  return escapeHtmlText(text);
}

function renderRichMath(el, raw='') {
  if (!el) return;
  const text = String(raw || '');
  if (!hasMathLikeContent(text)) {
    el.innerHTML = formatEnumeratedTextHtml(text);
    return;
  }
  el.innerHTML = sanitizeRichMathHtml(text);
}

