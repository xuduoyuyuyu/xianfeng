    '知识宇宙': 'var(--cl)',
    '学习中心': 'var(--cg)',
    '错题归因': 'var(--cr)',
    '成长洞察': 'var(--ca)',
    '家长端':   'var(--cpr)',
  };

  Object.entries(SB).forEach(([sec, items]) => {
    const isActive = sec === curSec;
    const wrap = document.createElement('div');
    wrap.className = 'tb-nav-item';

