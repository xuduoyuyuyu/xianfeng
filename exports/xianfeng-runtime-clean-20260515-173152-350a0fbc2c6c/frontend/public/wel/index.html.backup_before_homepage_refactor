    };
    if(!payload.name){ toast('昵称不能为空','err'); return; }
    if (payload.avatar_image && payload.avatar_image.length > 1800000) { toast('头像图片过大，请压缩后重试','err'); return; }
    const me = await api('PATCH','/api/me', payload);
