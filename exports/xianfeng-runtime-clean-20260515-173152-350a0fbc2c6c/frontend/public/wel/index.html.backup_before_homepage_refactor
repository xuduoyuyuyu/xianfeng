function resolveEntryRoute(defaultId=0) {
  const sp = new URLSearchParams(window.location.search || '');
  const raw = (sp.get('page') || sp.get('p') || '').trim();
  const alias = { home:0, map:1, resource:3, wrong:16, repair:19, report:21, parent:27, profile:29, textbook:52 };
  let id = Number.isFinite(Number(raw)) ? Number(raw) : alias[raw];
  if (!Number.isFinite(id)) id = defaultId;
  const extra = {};
  sp.forEach((v, k) => {
    if (k === 'page' || k === 'p') return;
    extra[k] = v;
  });
  return { id, extra };
}

const PAGE_ALIAS_BY_ID = {
  0:'home',1:'map',3:'resource',16:'wrong',19:'repair',21:'report',27:'parent',29:'profile',52:'textbook'
};
const PAGE_HOST_BY_ALIAS = {
  home:'home.localhost',
  map:'map.localhost',
  resource:'resource.localhost',
  wrong:'wrong.localhost',
  repair:'repair.localhost',
  report:'report.localhost',
  parent:'parent.localhost',
  profile:'profile.localhost',
  textbook:'textbook.localhost'
};

function updateEntryUrl(id, extra={}) {
  try {
    const sp = new URLSearchParams();
    sp.set('page', PAGE_ALIAS_BY_ID[id] || String(id));
    Object.entries(extra || {}).forEach(([k, v]) => {
      if (v === undefined || v === null) return;
      const t = typeof v;
      if (t !== 'string' && t !== 'number' && t !== 'boolean') return;
      const s = String(v);
      if (!s || s.length > 160) return;
      sp.set(k, s);
    });
    const next = `${window.location.pathname}?${sp.toString()}`;
    window.history.replaceState({ page:id }, '', next);
  } catch {}
}

function maybeSwitchHostByPage(id, extra={}) {
  try {
    const currentHost = (window.location.hostname || '').toLowerCase();
    const isLocalMode = currentHost === 'localhost' || currentHost === '127.0.0.1' || currentHost.endsWith('.localhost');
    if (!isLocalMode) return false;
    const alias = PAGE_ALIAS_BY_ID[id] || String(id);
    const targetHost = PAGE_HOST_BY_ALIAS[alias];
    if (!targetHost || targetHost === currentHost) return false;
    const sp = new URLSearchParams();
    sp.set('page', alias);
    Object.entries(extra || {}).forEach(([k, v]) => {
      if (v === undefined || v === null) return;
      const t = typeof v;
      if (t !== 'string' && t !== 'number' && t !== 'boolean') return;
      const s = String(v);
      if (!s || s.length > 160) return;
      sp.set(k, s);
    });
    const port = window.location.port ? `:${window.location.port}` : '';
    const path = window.location.pathname && window.location.pathname !== '/' ? window.location.pathname : '/';
    const next = `${window.location.protocol}//${targetHost}${port}${path}?${sp.toString()}`;
    window.location.assign(next);
    return true;
  } catch {
    return false;
  }
}

async function api(method, path, body) {
  const opts = {method, headers:{'Content-Type':'application/json','Authorization':`Bearer ${TOK}`}};
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(path, opts);
  const d = await r.json();
  if (!r.ok && d.error) throw new Error(d.error);
  return d;
}

