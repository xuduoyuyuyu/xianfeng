          if (textArea) textArea.innerHTML = wItem.ai_analysis.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
        }
      }

      // 拦截分析/归因按钮
      doc.querySelectorAll('button').forEach(btn => {
        const txt = btn.textContent.trim();
        if (txt.includes('归因') || txt.includes('分析') || txt.includes('诊断')) {
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            btn.textContent = 'AI 分析中...'; btn.disabled = true;
            try {
              const r = await api('POST',`/api/wrongs/${wItem.id}/analyze`);
              toast('AI归因完成！+30 XP'); xpPop(30);
              // 注入结果到页面
              const panels = doc.querySelectorAll('[class*="rounded-2xl"],[class*="panel"]');
              if (panels.length > 1) {
                const target = panels[2] || panels[1];
                target.innerHTML = `<div style="padding:16px;font-size:13px;line-height:1.7">
                  ${r.ai_analysis.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}
