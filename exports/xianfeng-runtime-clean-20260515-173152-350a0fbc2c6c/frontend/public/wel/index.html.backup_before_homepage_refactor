// AI 助手
// ═══════════════════════════════════════════════
let aiOpen    = false;
let aiHistory = [];
let aiTyping  = false;

function toggleAI() {
  aiOpen = !aiOpen;
  $id('ai-panel').classList.toggle('show', aiOpen);
  $id('ai-fab').style.transform = aiOpen ? 'rotate(20deg) scale(1.1)' : '';
  if (aiOpen && aiHistory.length === 0) aiGreet();
  if (aiOpen) setTimeout(() => $id('aip-input')?.focus(), 100);
}

function aiGreet() {
  const name = ME?.name || '同学';
  addMsg('ai', `你好 ${name}！我是 wel AI 助手 ✨\n\n可以帮你：\n• **解释知识点** — 说"解释一元二次方程"\n• **分析薄弱点** — 说"我哪里比较弱"\n• **出练习题** — 说"出一道数学题"\n• **今日计划** — 说"今天学什么"\n\n或直接问任何学习问题 👇`);
}

function addMsg(role, text) {
  const wrap = $id('aip-msgs');
  const d = document.createElement('div');
  d.className = `aip-msg ${role}`;
  // simple markdown: **bold**, newlines
  d.innerHTML = text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\n/g,'<br>');
  wrap.appendChild(d);
  wrap.scrollTop = wrap.scrollHeight;
  return d;
}

function showTypingDots() {
  const wrap = $id('aip-msgs');
  const d = document.createElement('div');
  d.id = 'aip-typing'; d.className = 'aip-msg ai';
  d.innerHTML = '<div class="aip-typing-dots"><span></span><span></span><span></span></div>';
  wrap.appendChild(d); wrap.scrollTop = wrap.scrollHeight;
}
function hideTypingDots() { $id('aip-typing')?.remove(); }

function aiShortcut(q) {
  $id('aip-input').value = q;
  sendAI();
}

function buildSystem() {
  return `你是 wel 智能教育平台的专属 AI 学习助手。
当前用户：${ME?.name||'学生'}，${ME?.grade||'初中'}，当前页面：${PAGES[curId]?.l||''}。
用简洁、鼓励的语气回答，解题分步骤，回答控制在 300 字以内（除非被要求详细），直接回答不要复述问题。`;
}

async function sendAI() {
  const inp = $id('aip-input');
  const text = inp.value.trim();
  if (!text || aiTyping) return;

  inp.value = ''; inp.style.height = 'auto';
  addMsg('user', text);
  aiHistory.push({ role:'user', content: text });

  // 快捷路由
  const lc = text.toLowerCase();
  if (lc.includes('薄弱') || lc.includes('弱点') || lc.includes('哪里比较弱')) return aiWeakAnalysis();
  if (lc.includes('今天学什么') || lc.includes('今日计划') || lc.includes('今天应该')) return aiTodayPlan();
  if (lc.includes('出一道') || lc.includes('出题') || lc.includes('练习题')) return aiQuiz(text);

  // 通用对话
  aiTyping = true;
  $id('aip-send').disabled = true;
  $id('aip-status').textContent = '● 思考中…';
  showTypingDots();
  try {
    const res = await api('POST', '/api/ai/chat', { prompt: text, system: buildSystem() });
    hideTypingDots();
    const reply = res.text || res.error || '抱歉，请重试';
    addMsg('ai', reply);
    aiHistory.push({ role:'assistant', content: reply });
  } catch(e) {
    hideTypingDots();
    addMsg('ai', `⚠️ 连接失败：${e.message}\n\n请确认服务器运行中，且已配置 ANTHROPIC_API_KEY。`);
  } finally {
    aiTyping = false;
    $id('aip-send').disabled = false;
    $id('aip-status').textContent = '● 随时可用';
  }
}

async function aiWeakAnalysis() {
  aiTyping = true; $id('aip-send').disabled = true;
  $id('aip-status').textContent = '● 分析中…';
  showTypingDots();
  try {
    const d = await api('GET', '/api/nodes');
    const weak = d.nodes.filter(n => n.mastery < 65).sort((a,b) => a.mastery - b.mastery).slice(0,5);
    if (!weak.length) {
      hideTypingDots();
      addMsg('ai', '🎉 太棒了！目前所有知识点掌握度都在65%以上，没有明显薄弱点。\n\n建议定期做测评，关注稳定性低于60的节点。');
      return;
    }
    const summary = weak.map(n=>`${n.subject}·${n.name}(${Math.round(n.mastery)}%)`).join('、');
    const res = await api('POST', '/api/ai/chat', {
      system: buildSystem(),
      prompt: `我的薄弱知识点：${summary}。请针对这些知识点：1)分析可能的原因 2)给出具体的学习建议 3)推荐复习顺序。`
    });
    hideTypingDots();
    addMsg('ai', res.text || `**你的薄弱点：**\n${weak.map(n=>`• ${n.subject} ${n.name}：${Math.round(n.mastery)}%`).join('\n')}`);
  } catch(e) {
    hideTypingDots();
    api('GET','/api/nodes').then(d=>{
      const weak = d.nodes.filter(n=>n.mastery<65).sort((a,b)=>a.mastery-b.mastery).slice(0,4);
      addMsg('ai', weak.length
        ? `**📊 薄弱知识点：**\n\n${weak.map(n=>`• **${n.subject} · ${n.name}**：${Math.round(n.mastery)}%`).join('\n')}\n\n建议从掌握度最低的开始，每次专注一个知识点。`
        : '暂时无法获取数据，请稍后重试。');
    }).catch(()=>addMsg('ai','获取数据失败，请重试。'));
  } finally {
    aiTyping = false; $id('aip-send').disabled = false;
    $id('aip-status').textContent = '● 随时可用';
  }
}

