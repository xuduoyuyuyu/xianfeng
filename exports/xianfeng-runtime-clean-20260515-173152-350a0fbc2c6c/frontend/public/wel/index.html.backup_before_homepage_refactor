function bridge_assessQuiz(w, pageId) {
  if (!curAssessId) return;
  api('GET',`/api/assessments/${curAssessId}/questions`).then(rawQs => {
    try {
      const doc = w.document;
      const isQuickPage = pageId === 10;
      const normalizeOpts = (v) => {
        if (Array.isArray(v)) return v.map(x => String(x || '').trim()).filter(Boolean);
        if (typeof v === 'string') {
          try {
            const arr = JSON.parse(v);
            if (Array.isArray(arr)) return arr.map(x => String(x || '').trim()).filter(Boolean);
          } catch(e) {}
        }
        return [];
      };
      const baseQs = Array.isArray(rawQs) ? rawQs.map(q => ({ ...q, opts: normalizeOpts(q?.opts) })) : [];
      const choiceQs = baseQs.filter(q => {
        const opts = q.opts || [];
        const isChoice = String(q?.form || q?.type || '').toLowerCase() === 'choice' || opts.length >= 2;
        return isChoice && opts.length >= 2;
      });
      const qs = isQuickPage ? choiceQs : baseQs;
      if (!qs.length) {
        toast('当前测评暂无可作答选择题','err');
        return;
      }
      const qIdx = isQuickPage ? getCurrentAssessQuestionIndex(qs.length) : (pageId - 9);  // page10走同页连续刷新
      curAssessQIdx = qIdx;
      const q = qs[qIdx]; if (!q) return;
      if (isQuickPage) {
        const pct = Math.max(0, Math.min(100, ((qIdx + 1) / Math.max(1, qs.length)) * 100));
        const pb = doc.getElementById('quick-progress-bar');
        if (pb) pb.style.width = `${pct}%`;
        const pt = doc.getElementById('quick-progress-text');
        if (pt) pt.textContent = `PROGRESS: ${String(qIdx + 1).padStart(2,'0')}/${String(Math.max(1, qs.length)).padStart(2,'0')}`;
      }
      const normalizeText = (v='') => String(v || '').trim().toLowerCase().replace(/\s+/g,'').replace(/[，。！？、,.!?;；:：'"“”‘’]/g,'');
      const asBool = (v='') => {
        const t = normalizeText(v);
        if (['对','正确','是','true','t','yes','y','√'].includes(t)) return true;
        if (['错','错误','否','false','f','no','n','×'].includes(t)) return false;
        return null;
      };
      const qTitle = doc.getElementById('assess-question-title') || [...doc.querySelectorAll('h1,h2')].find(el => (el.textContent || '').trim().length >= 6);
      if (qTitle) renderRichMath(qTitle, q.q || '');
      const visualWrap = doc.getElementById('assess-question-visual');
      if (visualWrap) {
        visualWrap.setAttribute('data-geom-theme', 'assess');
        visualWrap.setAttribute('data-geom-title', '几何图形高保真还原区域');
        visualWrap.classList.add('hidden');
        visualWrap.innerHTML = '';
        const qid = Number(q.question_id || 0);
        if (qid > 0) {
          api('GET', `/api/questions/${qid}/asset`).then(rs => {
            if (!rs) return;
            const img = String(rs.image_url || '').trim();
            const svg = String(rs.svg || '').trim();
            if (!img && !svg) return;
            renderGeometryComponent(visualWrap, rs, { theme: 'assess', title: '几何图形高保真还原区域' });
            visualWrap.classList.remove('hidden');
          }).catch(()=>{});
        }
      }
      const qNum = doc.getElementById('assess-qnum');
      if (qNum) qNum.textContent = `第 ${qIdx + 1} 题`;
      const clearOptText = (v='') => String(v || '').replace(/^[A-D][\.\):、\s]*/i, '').trim();
      const opts = (Array.isArray(q.opts) ? q.opts : []).slice(0,4);
      const optionNodes = [...doc.querySelectorAll('.assess-option')];
      const submitAndFlow = async (userAnswer) => {
        const userBool = asBool(userAnswer);
        const ansBool = asBool(q.ans || '');
        const isCorrect = (q.form === 'choice')
          ? String(userAnswer || '').toUpperCase() === String(q.ans || '').toUpperCase()
          : (ansBool !== null && userBool !== null ? userBool === ansBool : normalizeText(userAnswer) === normalizeText(q.ans || ''));
        try{
          await api('POST',`/api/assessments/${curAssessId}/answer`,{
            qnum: q.num, user_answer: userAnswer, is_correct: isCorrect, opts: q.opts
          });
        }catch(e){
          const latest = await api('GET', `/api/assessments/${curAssessId}/questions`);
          const hit = (Array.isArray(latest) ? latest : []).find(x => (x.question_id && q.question_id && Number(x.question_id)===Number(q.question_id)) || ((x.q||'')===(q.q||'')));
          if (!hit) throw e;
          await api('POST',`/api/assessments/${curAssessId}/answer`,{
            qnum: hit.num || q.num, user_answer: userAnswer, is_correct: isCorrect, opts: q.opts
          });
        }
        if (!isQuickPage) {
          if (isCorrect) { toast('回答正确！+20 XP'); xpPop(20); }
          else toast('已记录本题作答，继续下一题','info');
        }
        setTimeout(() => {
          if (isQuickPage) {
            if (curAssessQIdx < (qs.length - 1)) {
              curAssessQIdx += 1;
              go(10);
            } else {
              api('POST',`/api/assessments/${curAssessId}/complete`,{time_spent:300}).then(r=>{
                toast(`测评完成！得分${r.score}分，+${r.xp_gained} XP`);
                xpPop(r.xp_gained);
                ME.xp += r.xp_gained; updateUserUI();
                go(21);
              });
            }
            return;
          }
          if (pageId < 11) go(pageId + 1);
          else {
            api('POST',`/api/assessments/${curAssessId}/complete`,{time_spent:300}).then(r=>{
              toast(`测评完成！得分${r.score}分，+${r.xp_gained} XP`);
              xpPop(r.xp_gained);
              ME.xp += r.xp_gained; updateUserUI();
              go(21);
            });
          }
        }, 120);
      };
      optionNodes.forEach((node, i) => {
        const letter = ['A','B','C','D'][i];
        const raw = opts[i] || '';
        const text = clearOptText(raw);
        const letterEl = node.querySelector('[data-opt-letter]');
        const textEl = node.querySelector('[data-opt-text]');
        if (letterEl) letterEl.textContent = letter;
        if (textEl) renderRichMath(textEl, text || raw || `选项 ${letter}`);
        node.style.display = raw ? '' : 'none';
        node.onclick = raw ? (() => submitAndFlow(letter)) : null;
      });
      const visibleOptionCount = optionNodes.filter(n => n.style.display !== 'none').length;
      let panel = doc.getElementById('assess-dynamic-answer-panel');
      if (!panel) {
        panel = doc.createElement('div');
        panel.id = 'assess-dynamic-answer-panel';
        panel.className = 'fixed left-1/2 -translate-x-1/2 bottom-8 z-50 bg-white/95 backdrop-blur-md border border-[#7f13ec22] rounded-2xl shadow-xl p-3 max-w-3xl w-[min(92vw,840px)]';
        doc.body.appendChild(panel);
      }
      if (visibleOptionCount > 0) {
        panel.style.display = 'none';
      } else if (q.form === 'choice' && opts.length) {
        panel.style.display = '';
        panel.innerHTML = '<div data-dyn-grid style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;"></div>';
        const dynGrid = panel.querySelector('[data-dyn-grid]');
        opts.forEach((o,i) => {
          if (!dynGrid) return;
          const b = doc.createElement('button');
          b.setAttribute('data-dyn-opt', String(i));
          b.style.cssText = 'height:44px;border-radius:12px;border:1px solid #e2e8f0;background:#fff;font-weight:700;color:#334155;';
          renderRichMath(b, clearOptText(o) || o);
          dynGrid.appendChild(b);
        });
        [...panel.querySelectorAll('[data-dyn-opt]')].forEach(btn => {
          const i = Number(btn.getAttribute('data-dyn-opt') || 0);
          const letter = ['A','B','C','D'][i] || 'A';
          btn.onclick = () => submitAndFlow(letter);
        });
      } else {
        panel.style.display = '';
        panel.innerHTML = `<div style="display:flex;gap:8px;align-items:center;"><input id="assess-dyn-input" placeholder="请输入答案后提交" style="flex:1;height:42px;border:1px solid #e2e8f0;border-radius:10px;padding:0 12px;outline:none;" /><button id="assess-dyn-submit" style="height:42px;padding:0 16px;border-radius:10px;background:#7f13ec;color:#fff;font-weight:700;">提交答案</button></div>`;
        const input = panel.querySelector('#assess-dyn-input');
        const submit = panel.querySelector('#assess-dyn-submit');
        const doSubmit = () => {
          const v = String(input?.value || '').trim();
          if (!v) return;
          submitAndFlow(v);
        };
        if (submit) submit.onclick = doSubmit;
        if (input) input.onkeydown = (e) => { if (e.key === 'Enter') doSubmit(); };
      }
    } catch(e) { console.warn('quiz bridge', e); }
  }).catch(()=>{});
}

