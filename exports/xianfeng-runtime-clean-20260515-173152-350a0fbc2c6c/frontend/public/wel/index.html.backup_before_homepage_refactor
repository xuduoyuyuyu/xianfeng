  api('GET','/api/wrongs').then(d=>{
    const el=$id('wb'); if(el) el.textContent=d.pending||'';
  }).catch(()=>{});
}

function _navOutsideClick(e) {
  if (!e.target.closest('.tb-nav-item')) {
    document.querySelectorAll('.tb-nav-item').forEach(item => {
      const dd = item.querySelector('.tb-dropdown');
      if (dd) { dd.style.opacity='0'; dd.style.visibility='hidden'; dd.style.transform='translateY(6px) scale(0.98)'; dd.style.pointerEvents='none'; }
      item.classList.remove('dd-open');
      const arr = item.querySelector('.arr'); if (arr) arr.style.transform='';
    });
  }
}

