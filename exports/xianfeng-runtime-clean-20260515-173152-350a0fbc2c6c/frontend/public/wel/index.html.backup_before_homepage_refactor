        if (hasVisual) renderGeometryComponent(visualHost, rs || {}, { theme: 'practice', title: '几何图形高保真还原区域' });
      }).catch(() => {
        if (reqId !== PRACTICE_STATE.figureReqId) return;
        setPracticeVisualVisible(false);
      });
