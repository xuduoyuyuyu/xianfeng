      const kpFreq = new Map();
      list.forEach((q) => {
        const kp = String(q.kp || '专项训练').trim();
        kpFreq.set(kp, (kpFreq.get(kp) || 0) + 1);
      });
      const ranked = [...kpFreq.entries()].sort((a,b)=>b[1]-a[1]).map(x=>x[0]);
      const candidateBooks = allRes
        .map(r => {
          const titleBlob = `${r.title || ''} ${r.version || ''} ${r.overview || ''}`;
          let score = 0;
          if (String(r.subject || '') === mainSubject) score += 60;
          if (gradeToken && String(r.grade || '').includes(gradeToken)) score += 28;
          if (gradeText && String(r.grade || '').includes(gradeText)) score += 16;
          if (cityVersionKeywords.some(k => titleBlob.includes(k))) score += 24;
          score += Math.min(12, Number(r.chapter_count || 0));
          score += Math.min(8, Number(r.nodes_count || 0) / 10);
          return { ...r, _score: score };
        })
        .filter(r => r._score > 30)
        .sort((a,b)=>b._score-a._score)
        .slice(0, 4);
      let chosenTextbook = null;
      let chosenStructure = [];
      for (const tb of candidateBooks) {
        try {
          const detail = await api('GET', `/api/textbooks/${tb.id}`);
          const st = Array.isArray(detail?.structure) ? detail.structure : [];
          if (st.length) {
            chosenTextbook = tb;
            chosenStructure = st;
            break;
          }
        } catch(e) {}
      }
      const modulesFromCatalog = [];
      const seenModule = new Set();
      chosenStructure.forEach(ch => {
        (ch.sections || []).forEach(sec => {
          const secName = String(sec.name || '').trim();
          if (secName && secName.length >= 2 && !seenModule.has(secName)) {
            seenModule.add(secName);
            modulesFromCatalog.push(secName);
          }
          (sec.knowledge_points || []).forEach(kp => {
            const kn = String(kp.name || '').trim();
            if (kn && kn.length >= 2 && !seenModule.has(kn)) {
              seenModule.add(kn);
              modulesFromCatalog.push(kn);
            }
          });
        });
      });
      const rankByQuestion = (name) => {
        let score = 0;
        for (const q of list) {
          const kp = String(q.kp || '');
          const qq = String(q.q || '');
          if (kp && (kp.includes(name) || name.includes(kp))) score += 5;
          if (qq && qq.includes(name)) score += 2;
        }
        return score;
      };
      const rankedCatalogModules = modulesFromCatalog
        .map(name => ({ name, score: rankByQuestion(name) }))
        .sort((a,b)=>b.score-a.score)
        .map(x=>x.name);
      const modulePool = rankedCatalogModules.length ? rankedCatalogModules : ranked;
      const headerDesc = doc.querySelector('main p.text-slate-400');
      if (headerDesc) {
        const bookName = chosenTextbook?.title ? `《${chosenTextbook.title}》` : '教材目录';
        headerDesc.textContent = `基于${city || '当前地区'} · ${gradeText || '当前年级'} · ${mainSubject}，按${bookName}生成专项模块`;
      }
      const cards = [...doc.querySelectorAll('.pearl-card')].filter(c => c.querySelector('button'));
      cards.forEach((card, i) => {
        const title = card.querySelector('h3');
        const desc = card.querySelector('p');
        const badge = card.querySelector('span');
        const btn = card.querySelector('button');
        const moduleName = modulePool[i] || '';
        if (title && moduleName) title.textContent = moduleName;
        if (desc && moduleName) {
          const sourceName = chosenTextbook?.title ? `《${chosenTextbook.title}》` : '教材目录';
          desc.textContent = `基于${sourceName}匹配，适配${city || '当前地区'}·${gradeText || '当前年级'}，可练 ${Math.max(3, Math.min(20, list.length || 12))} 题`;
        }
        if (badge && moduleName) badge.textContent = i % 2 === 0 ? '教材目录' : '重点模块';
        if (!btn || btn.dataset.boundSpecialist === '1') return;
        btn.textContent = '开始突击';
        btn.dataset.boundSpecialist = '1';
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const picked = moduleName || '';
          let targetIdx = 0;
          if (picked && list.length) {
            const idx = list.findIndex(q => String(q.kp || '').includes(picked) || picked.includes(String(q.kp || '')) || String(q.q || '').includes(picked));
            if (idx >= 0) targetIdx = idx;
          }
          curAssessQIdx = targetIdx;
          go(9);
        });
      });
    } catch(e) { console.warn('assessSpecialist bridge', e); }
  }).catch(()=>{});
}

