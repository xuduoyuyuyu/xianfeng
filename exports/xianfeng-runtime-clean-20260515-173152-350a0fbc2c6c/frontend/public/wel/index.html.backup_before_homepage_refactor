function bridge_dashboard(w) {
  api('GET','/api/dashboard').then(d=>{
    try {
      const doc = w.document;
      ME = d.user;
      updateUserUI();

      // 用户名
      doc.querySelectorAll('[class*="text-2xl"],[class*="text-3xl"]').forEach(el => {
        if (el.textContent.includes('探索者')) el.innerHTML = el.innerHTML.replace('探索者', ME.name);
      });

      // XP 进度条
      const xpPct = Math.round(((ME.xp||0) % 1000) / 1000 * 100);
      doc.querySelectorAll('[class*="w-["]').forEach(el => {
        if (el.style.width && el.style.width.includes('%')) el.style.width = xpPct+'%';
      });

      // 今日任务 — 找第一个任务列表容器，注入真实数据
      const taskAreas = doc.querySelectorAll('[class*="space-y"]');
      taskAreas.forEach(area => {
        const items = area.querySelectorAll('[class*="rounded"]');
        if (items.length >= 2 && d.tasks.length) {
          d.tasks.forEach((task, i) => {
            const item = items[i];
            if (!item) return;
            // 标题
            const titleEl = item.querySelector('[class*="font-bold"],[class*="font-semibold"]');
            if (titleEl && !titleEl.textContent.includes('zhi')) titleEl.textContent = task.title;
            // 完成按钮
            if (task.status === 'pending') {
              const btn = item.querySelector('button');
              if (btn) btn.onclick = async () => {
                try {
                  const r = await api('POST', `/api/tasks/${task.id}/done`);
                  toast(`完成「${task.title}」+${r.xp_gained} XP`);
                  xpPop(r.xp_gained);
                  ME.xp += r.xp_gained;
                  updateUserUI();
                  btn.disabled = true; btn.style.opacity = '0.5';
                } catch(e) { toast(e.message,'err'); }
              };
            }
          });
        }
      });

      const weekTasks = Array.isArray(d.week_tasks) ? d.week_tasks : [];
      const weekMap = {};
      weekTasks.forEach(t => {
        const k = String(t.scheduled_date || '');
        if (!k) return;
        (weekMap[k] = weekMap[k] || []).push(t);
      });
      const weekStart = new Date();
      const day = weekStart.getDay();
      const delta = day === 0 ? -6 : (1 - day);
      weekStart.setDate(weekStart.getDate() + delta);
      const dateKeys = Array.from({length:7}).map((_,i)=>{
        const d0 = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + i);
        return `${d0.getFullYear()}-${String(d0.getMonth()+1).padStart(2,'0')}-${String(d0.getDate()).padStart(2,'0')}`;
      });
      const top7 = [...doc.querySelectorAll('div')].find(el => (el.className||'').includes('grid-cols-7') && (el.className||'').includes('mb-4') && (el.className||'').includes('text-center'));
      if (top7) {
        const cols = top7.querySelectorAll(':scope > div');
        cols.forEach((col, idx) => {
          const key = dateKeys[idx];
          const dd = Number((key || '').split('-')[2] || 0);
          const dayNum = col.querySelector('[class*="text-2xl"],[class*="text-3xl"]');
          if (dayNum && dd) dayNum.textContent = String(dd);
        });
      }
      const col7 = [...doc.querySelectorAll('div')].find(el => (el.className||'').includes('grid-cols-7') && (el.className||'').includes('h-[300px]'));
      if (col7) {
        const cols = col7.querySelectorAll(':scope > div');
        cols.forEach((col, idx) => {
          const key = dateKeys[idx];
          const arr = (weekMap[key] || []).slice(0, 3);
          col.innerHTML = arr.map((t, i) => {
            const hot = (t.task_type || '').includes('plan') && i === 0;
            return `<div class="rounded-xl p-3 mb-2 ${hot ? 'bg-primary text-white' : 'bg-slate-50'}"><div class="text-xs font-black">${String(t.title||'学习任务').slice(0,20)}</div><div class="text-[10px] ${hot ? 'text-white/80':'text-slate-500'}">${Number(t.progress_total||30)} 分钟</div></div>`;
          }).join('') || '<div class="text-xs text-slate-300 p-2 rounded-xl border border-dashed border-slate-200">+</div>';
        });
      }

      // 待归因错题数
      doc.querySelectorAll('[class*="text-4xl"],[class*="text-5xl"]').forEach(el => {
        if (el.textContent.match(/^\d+$/) || el.textContent.includes('42'))
          el.textContent = d.pending_wrong;
      });

    } catch(e) { console.warn('dashboard bridge', e); }
  }).catch(()=>{});
}

