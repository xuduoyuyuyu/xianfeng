function fetchReportCached(path, ttlMs = 120000){
  const now = Date.now();
  const hit = REPORT_REQ_CACHE[path];
  if(hit && hit.data && now < hit.expireAt) return Promise.resolve(hit.data);
  if(hit && hit.pending) return hit.pending;
  const pending = api('GET', path).then(d=>{
    REPORT_REQ_CACHE[path] = { data:d, expireAt: Date.now() + Math.max(10000, ttlMs) };
    return d;
  }).catch(e=>{
    const cur = REPORT_REQ_CACHE[path];
    if(cur && cur.pending) delete REPORT_REQ_CACHE[path];
    throw e;
  });
  REPORT_REQ_CACHE[path] = { pending };
  return pending;
}

