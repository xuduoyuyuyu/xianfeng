          doc.querySelectorAll('.list-row[data-wid-open]').forEach(node => {
            node.addEventListener('click', (e) => {
              const btn = e.target.closest('button');
              if (btn) return;
              const wid = Number(node.getAttribute('data-wid-open') || 0);
              if (!wid) return;
              curWrongId = wid;
              go(18);
            });
          });
        };
        const repaintControls = () => {
          if (subjectSel) subjectSel.value = WRONG_LIST_UI.subject;
          if (statusBtn) {
            const pCnt = pendingCntBySubject();
            statusBtn.textContent = WRONG_LIST_UI.pendingOnly ? `待归因 (${pCnt})` : '待归因';
            statusBtn.classList.toggle('bg-white', !WRONG_LIST_UI.pendingOnly);
            statusBtn.classList.toggle('border-slate-200', !WRONG_LIST_UI.pendingOnly);
            statusBtn.classList.toggle('text-slate-600', !WRONG_LIST_UI.pendingOnly);
            statusBtn.classList.toggle('bg-primary/5', WRONG_LIST_UI.pendingOnly);
            statusBtn.classList.toggle('border-primary/20', WRONG_LIST_UI.pendingOnly);
            statusBtn.classList.toggle('text-primary', WRONG_LIST_UI.pendingOnly);
          }
          if (groupBtn) {
            groupBtn.classList.toggle('toggle-button-active', WRONG_LIST_UI.groupByTopic);
            const txtEl = groupBtn.querySelector('span:last-child');
            if (txtEl) txtEl.textContent = WRONG_LIST_UI.groupByTopic ? '按知识点聚合' : '按时间列表';
          }
        };
        repaintControls();
        renderRows();
        if (subjectSel) subjectSel.onchange = () => {
          const nextSubject = subjectSel.value || 'all';
          if (nextSubject !== WRONG_LIST_UI.subject) WRONG_LIST_UI.pendingOnly = false;
          WRONG_LIST_UI.subject = nextSubject;
          WRONG_LIST_UI.page = 1;
          repaintControls();
          renderRows();
        };
        if (statusBtn) statusBtn.onclick = () => { WRONG_LIST_UI.pendingOnly = !WRONG_LIST_UI.pendingOnly; WRONG_LIST_UI.page = 1; repaintControls(); renderRows(); };
        if (groupBtn) groupBtn.onclick = () => { WRONG_LIST_UI.groupByTopic = !WRONG_LIST_UI.groupByTopic; WRONG_LIST_UI.page = 1; repaintControls(); renderRows(); };
        if (sortSel) sortSel.onchange = () => { WRONG_LIST_UI.sort = sortSel.value || 'created_at'; WRONG_LIST_UI.page = 1; renderRows(); };
        if (importBtn) importBtn.onclick = () => { openWrongImportModal(); };
      }
      doc.querySelectorAll('button').forEach(btn => {
        const txt = btn.textContent.trim();
        const aiWid = Number(btn.getAttribute('data-wid-ai') || 0);
        const rpWid = Number(btn.getAttribute('data-wid-rp') || 0);
        if (aiWid) {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            curWrongId = aiWid;
            go(19);
          });
          return;
        }
        if (rpWid) {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            startRepairPractice(rpWid);
          });
          return;
        }
        if (txt.includes('AI') && txt.includes('归因')) {
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            const pending = d.items.filter(x=>x.status==='pending');
            if (!pending.length) { toast('所有错题已归因完毕 ✓'); return; }
            curWrongId = pending[0].id;
            go(19);
          });
        }
        if (txt.includes('点击修复') || txt.includes('错题修复')) {
          btn.addEventListener('click', () => {
            const first = (d.items || [])[0];
            if (!first) return toast('当前没有可修复错题','info');
            startRepairPractice(first.id);
          });
        }
        if (txt.includes('批量归因')) {
          btn.addEventListener('click', async () => {
            toast('AI批量归因中...','info');
            try {
              const r = await api('POST','/api/wrongs/batch-analyze',{});
              toast(`批量归因完成，处理了${r.count}道题`);
              xpPop(r.count * 30);
            } catch(e) { toast(e.message,'err'); }
          });
        }
        if (txt.includes('错题导入')) btn.addEventListener('click',()=>window.location.assign('http://repair.localhost:8888/index.html?page=17'));
        if (txt.includes('同步上传')) btn.addEventListener('click',()=>window.location.assign('http://repair.localhost:8888/index.html?page=17'));
      });
    } catch(e) { console.warn('wrongList bridge', e); }
  }).catch(()=>{});
}

function openWrongImportModal(){
