      PRACTICE_STATE.idx = idx;
      const it = PRACTICE_STATE.items[idx];
      PRACTICE_STATE.currentSubject = String(it.subject || '').trim();
      const topic = String(it.topic || (PRACTICE_STATE.topics[0]||{}).topic || it.subject || '知识点').trim();
      if (titleEl) titleEl.textContent = PRACTICE_STATE.repairMode ? `错题重练：${topic}` : `同类强化：${topic}`;
      if (counterEl) counterEl.textContent = `Question ${String(idx+1).padStart(2,'0')} / ${String(total).padStart(2,'0')}`;
      if (qEl) renderRichMath(qEl, String(it.question || '暂无题目'));
      renderPracticeAnswer(it, idx);
      renderPracticeVisual(it);
      const mastery = Math.max(35, Math.min(95, Math.round(52 + (idx / Math.max(1,total-1)) * 35)));
      if (masteryEl) masteryEl.textContent = `${mastery}% 掌握度验证中`;
      if (bar) bar.style.width = `${Math.round(((idx+1)/total)*100)}%`;
      if (aiBadge) {
        const p = String(it.node_path || '').trim();
        aiBadge.textContent = PRACTICE_STATE.repairMode
          ? `错题重练 · 来源：错题归因${p ? ` · ${p}` : ''}`
          : `AI 精准匹配 · ${topic}${p ? ` · ${p}` : ''}`;
      }
      if (scratchHint) {
        const noteKey = String(it.id || idx);
        const draft = String(PRACTICE_STATE.notes[noteKey] || '').trim();
        scratchHint.textContent = draft || draftPlaceholder;
        scratchHint.style.fontStyle = draft ? 'normal' : 'italic';
        scratchHint.style.color = draft ? '#334155' : '';
      }
    };
    const loadPractice = () => {
      if (PRACTICE_STATE.repairItem) {
        PRACTICE_STATE.items = [PRACTICE_STATE.repairItem];
        PRACTICE_STATE.topics = [{ topic: PRACTICE_STATE.repairItem.topic || '错题重练', subject: PRACTICE_STATE.repairItem.subject || '', wrong_count: 1 }];
        PRACTICE_STATE.idx = 0;
        renderSubjectOptions();
        render();
        return;
      }
      const cfg = PRACTICE_STATE.settings || { limit:12, difficulty:'all', time:20, subjects:[] };
      const qp = new URLSearchParams();
      qp.set('limit', String(cfg.limit || 12));
      qp.set('difficulty', String(cfg.difficulty || 'all'));
      qp.set('time', String(cfg.time || 20));
      qp.set('subjects', (cfg.subjects || []).join(','));
      api('GET',`/api/practice/wrong-drill?${qp.toString()}`).then(d=>{
        PRACTICE_STATE.items = Array.isArray(d.items) ? d.items : [];
        PRACTICE_STATE.topics = Array.isArray(d.target_topics) ? d.target_topics : [];
        PRACTICE_STATE.idx = 0;
        const fromServer = d.settings || {};
        if (Array.isArray(fromServer.subjects)) PRACTICE_STATE.settings.subjects = fromServer.subjects;
        if (fromServer.time) PRACTICE_STATE.settings.time = Number(fromServer.time) || PRACTICE_STATE.settings.time;
        if (Array.isArray(fromServer.available_subjects)) PRACTICE_STATE.subjectOptions = fromServer.available_subjects;
        renderSubjectOptions();
        render();
      }).catch(()=>{});
    };
    const collectSubjectOptions = () => {
      if (Array.isArray(PRACTICE_STATE.subjectOptions) && PRACTICE_STATE.subjectOptions.length) {
        return [...new Set(PRACTICE_STATE.subjectOptions.map(x => String(x || '').trim()).filter(Boolean))];
      }
      const a = (PRACTICE_STATE.topics || []).map(x => String(x.subject || '').trim()).filter(Boolean);
      const b = (PRACTICE_STATE.items || []).map(x => String(x.subject || '').trim()).filter(Boolean);
      return [...new Set([...a, ...b])];
    };
    const renderSubjectOptions = () => {
      if (!settingsSubjects) return;
      const opts = collectSubjectOptions();
      const selected = new Set(PRACTICE_STATE.settings.subjects || []);
      if (!opts.length) {
        settingsSubjects.innerHTML = '<div class="text-slate-400 text-[11px] py-1">暂无可选学科（将按全部学科推荐）</div>';
        return;
      }
      settingsSubjects.innerHTML = opts.map(s => {
        const on = selected.has(s);
        return `<button type="button" data-practice-subj-opt data-value="${s}" class="${on ? 'border-primary/40 text-primary bg-primary/5' : 'border-primary/20 text-slate-700 bg-white'} px-3 py-1.5 rounded-xl border border-dashed font-semibold hover:border-primary/50 transition-all">${s}</button>`;
      }).join('');
      settingsSubjects.querySelectorAll('[data-practice-subj-opt]').forEach(btn => {
        btn.onclick = () => {
          const v = String(btn.getAttribute('data-value') || '').trim();
          if (!v) return;
          const set = new Set(PRACTICE_STATE.settings.subjects || []);
          if (set.has(v)) set.delete(v); else set.add(v);
          PRACTICE_STATE.settings.subjects = [...set];
          renderSubjectOptions();
          if (settingsApplyTimer) clearTimeout(settingsApplyTimer);
          settingsApplyTimer = setTimeout(() => applySettings(), 260);
        };
      });
    };
    const openSettings = () => {
      if (!settingsMask) return;
      if (settingsLimit) settingsLimit.value = String(PRACTICE_STATE.settings.limit || 12);
      if (settingsLimitText) settingsLimitText.textContent = `${PRACTICE_STATE.settings.limit || 12} 题`;
      if (settingsDifficulty) settingsDifficulty.value = String(Math.max(0, DIFF_VALUES.indexOf(String(PRACTICE_STATE.settings.difficulty || 'all'))));
      if (settingsDifficultyText) settingsDifficultyText.textContent = DIFF_LABELS[String(PRACTICE_STATE.settings.difficulty || 'all')] || '全部难度';
      if (settingsTime) settingsTime.value = String(PRACTICE_STATE.settings.time || 20);
      if (settingsTimeText) settingsTimeText.textContent = `${PRACTICE_STATE.settings.time || 20} 分钟`;
      renderSubjectOptions();
      settingsMask.classList.remove('hidden');
      settingsMask.classList.add('flex');
    };
    const closeSettings = () => {
      if (!settingsMask) return;
      settingsMask.classList.add('hidden');
      settingsMask.classList.remove('flex');
    };
    const applySettings = () => {
      PRACTICE_STATE.settings.limit = Number(settingsLimit?.value || 12);
      PRACTICE_STATE.settings.difficulty = DIFF_VALUES[Number(settingsDifficulty?.value || 0)] || 'all';
      PRACTICE_STATE.settings.time = Number(settingsTime?.value || 20);
      if (settingsLimitText) settingsLimitText.textContent = `${PRACTICE_STATE.settings.limit} 题`;
      if (settingsDifficultyText) settingsDifficultyText.textContent = DIFF_LABELS[PRACTICE_STATE.settings.difficulty] || '全部难度';
      if (settingsTimeText) settingsTimeText.textContent = `${PRACTICE_STATE.settings.time} 分钟`;
      loadPractice();
    };
    if (settingsMask) settingsMask.onclick = (e) => { if (e.target === settingsMask) closeSettings(); };
    if (settingsClose) settingsClose.onclick = (e) => { e.preventDefault(); closeSettings(); };
    if (settingsLimit) settingsLimit.oninput = () => {
      PRACTICE_STATE.settings.limit = Number(settingsLimit.value || 12);
      if (settingsLimitText) settingsLimitText.textContent = `${PRACTICE_STATE.settings.limit} 题`;
    };
    if (settingsLimit) settingsLimit.onchange = applySettings;
    if (settingsDifficulty) settingsDifficulty.oninput = () => {
      const key = DIFF_VALUES[Number(settingsDifficulty.value || 0)] || 'all';
      PRACTICE_STATE.settings.difficulty = key;
      if (settingsDifficultyText) settingsDifficultyText.textContent = DIFF_LABELS[key] || '全部难度';
    };
    if (settingsDifficulty) settingsDifficulty.onchange = applySettings;
    if (settingsTime) settingsTime.oninput = () => {
      PRACTICE_STATE.settings.time = Number(settingsTime.value || 20);
      if (settingsTimeText) settingsTimeText.textContent = `${PRACTICE_STATE.settings.time} 分钟`;
    };
    if (settingsTime) settingsTime.onchange = applySettings;
    if (scratchHint) {
      scratchHint.onfocus = () => {
        const v = String(scratchHint.textContent || '').trim();
        if (v === draftPlaceholder) {
          scratchHint.textContent = '';
          scratchHint.style.fontStyle = 'normal';
          scratchHint.style.color = '#334155';
        }
      };
      scratchHint.onblur = () => {
        const item = PRACTICE_STATE.items[PRACTICE_STATE.idx] || {};
        const noteKey = String(item.id || PRACTICE_STATE.idx);
        const v = String(scratchHint.textContent || '').trim();
        PRACTICE_STATE.notes[noteKey] = v;
        if (!v) {
          scratchHint.textContent = draftPlaceholder;
          scratchHint.style.fontStyle = 'italic';
          scratchHint.style.color = '';
        }
      };
    }
    if (prevBtn) prevBtn.onclick = (e) => { e.preventDefault(); if (!PRACTICE_STATE.items.length) return; PRACTICE_STATE.idx = Math.max(0, PRACTICE_STATE.idx - 1); render(); };
    if (nextBtn) nextBtn.onclick = (e) => {
      e.preventDefault();
      if (!PRACTICE_STATE.items.length) return;
      const cur = PRACTICE_STATE.items[PRACTICE_STATE.idx] || {};
      const ans = getPracticeAnswer(cur, PRACTICE_STATE.idx);
      if (!ans) {
        toast('请输入答案');
        return;
      }
      if (PRACTICE_STATE.idx >= PRACTICE_STATE.items.length - 1) {
        if (PRACTICE_STATE.repairMode) {
          const wid = Number(PRACTICE_STATE.repairWrongId || 0);
          if (wid) {
            api('POST', `/api/wrongs/${wid}/repair`).then(r => {
              if (Number(r?.xp_gained || 0) > 0) {
                xpPop(r.xp_gained);
                ME.xp = (ME.xp || 0) + r.xp_gained;
                updateUserUI();
              }
            }).catch(()=>{});
          }
          PRACTICE_STATE.repairMode = false;
          PRACTICE_STATE.repairItem = null;
          PRACTICE_STATE.repairWrongId = 0;
          toast('重做完成，已返回错题归因');
          go(16);
          return;
        }
        toast('本轮强化练习完成！');
        go(16);
        return;
      }
      PRACTICE_STATE.idx += 1;
      render();
    };
    if (skipBtn) skipBtn.onclick = (e) => {
      e.preventDefault();
      if (!PRACTICE_STATE.items.length) return;
      PRACTICE_STATE.idx = Math.min(PRACTICE_STATE.items.length - 1, PRACTICE_STATE.idx + 1);
      render();
    };
    if (clearBtn) clearBtn.onclick = (e) => {
      e.preventDefault();
      if (!PRACTICE_STATE.items.length) return;
      const item = PRACTICE_STATE.items[PRACTICE_STATE.idx] || {};
      PRACTICE_STATE.notes[String(item.id || PRACTICE_STATE.idx)] = '';
      if (scratchHint) {
        scratchHint.textContent = draftPlaceholder;
        scratchHint.style.fontStyle = 'italic';
        scratchHint.style.color = '';
      }
      toast('草稿已清空');
    };
    settingsBtns.forEach(btn => {
      btn.onclick = (e) => { e.preventDefault(); openSettings(); };
    });
    if (drawBtn) drawBtn.onclick = (e) => {
      e.preventDefault();
      if (scratchHint) scratchHint.focus();
      toast('已进入草稿记录模式');
    };
    if (aiHintBtn) aiHintBtn.onclick = (e) => {
      e.preventDefault();
      const item = PRACTICE_STATE.items[PRACTICE_STATE.idx] || {};
      const exp = String(item.explanation || '').trim();
      if (!exp) { toast('当前题暂无解析提示','info'); return; }
      if (scratchHint) {
        scratchHint.textContent = `参考解析：${exp.slice(0,180)}${exp.length>180?'...':''}`;
        scratchHint.style.fontStyle = 'normal';
        scratchHint.style.color = '#334155';
      }
    };
    loadPractice();
  }catch(e){ console.warn('practice bridge', e); }
}

// ─── BRIDGE: 错题中心 (page 16) ──────────
function bridge_wrongList(w) {
  api('GET','/api/wrongs').then(d=>{
    try {
      const doc = w.document;
      doc.querySelectorAll('[class*="text-4xl"],[class*="text-5xl"],[class*="text-3xl"]').forEach(el => {
        if (/^\d+$/.test(el.textContent.trim())) el.textContent = d.total;
      });
      doc.querySelectorAll('[class*="text-amber"],[class*="text-yellow"]').forEach(el => {
        if (el.textContent.includes('待归因')) el.textContent = `待归因 (${d.pending})`;
      });
      const listWrap = doc.querySelector('.glass-card .divide-y');
      const esc = (s='') => String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
      const allItems = Array.isArray(d.items) ? d.items : [];
      const startRepairPractice = (wid) => {
        const it = allItems.find(x => Number(x.id || 0) === Number(wid || 0));
        if (!it) { toast('未找到该错题','err'); return; }
        PRACTICE_STATE.repairMode = true;
        PRACTICE_STATE.repairWrongId = Number(it.id || 0);
        PRACTICE_STATE.repairItem = {
          id: `wr_${it.id}`,
          question: String(it.question || '').trim() || '暂无题目',
          subject: String(it.subject || '').trim(),
          topic: String(it.topic || it.subject || '错题重练').trim(),
          explanation: String(it.error_reason || it.ai_summary || '').trim(),
          node_path: String(it.textbook_binding || '').trim(),
          source: '错题归因'
        };
        PRACTICE_STATE.settings = PRACTICE_STATE.settings || { limit:12, difficulty:'all', time:20, subjects:[] };
        PRACTICE_STATE.settings.subjects = PRACTICE_STATE.repairItem.subject ? [PRACTICE_STATE.repairItem.subject] : [];
        toast('已加载原题，开始重做');
        go(12);
      };
      if (listWrap && Array.isArray(d.items)) {
        const subjectSel = doc.querySelector('[data-wl-subject]');
        const statusBtn = doc.querySelector('[data-wl-status]');
        const groupBtn = doc.querySelector('[data-wl-group]');
        const sortSel = doc.querySelector('[data-wl-sort]');
        const importBtn = doc.querySelector('[data-wl-import]');
        const summaryEl = doc.querySelector('[data-wl-summary]');
        const pagePrevBtn = doc.querySelector('[data-wl-page-prev]');
        const pageNextBtn = doc.querySelector('[data-wl-page-next]');
        const pageListEl = doc.querySelector('[data-wl-page-list]');
        const subjects = ['all', ...Object.keys(d.by_subject || {}).sort((a,b)=>a.localeCompare(b,'zh-Hans-CN'))];
        if (!subjects.includes(WRONG_LIST_UI.subject)) WRONG_LIST_UI.subject = 'all';
        if (subjectSel) {
          subjectSel.innerHTML = subjects.map(s => `<option value="${esc(s)}">${s === 'all' ? '全部' : esc(s)}</option>`).join('');
          subjectSel.value = WRONG_LIST_UI.subject;
        }
        if (sortSel) sortSel.value = WRONG_LIST_UI.sort;
        const pendingCntBySubject = () => {
          const base = allItems.filter(it => WRONG_LIST_UI.subject === 'all' ? true : String(it.subject||'') === WRONG_LIST_UI.subject);
          return base.filter(x => String(x.status||'') === 'pending').length;
        };
        const applySort = (arr) => {
          const out = [...arr];
          if (WRONG_LIST_UI.sort === 'wrong_count') {
            out.sort((a,b)=>Number(b.wrong_count||1)-Number(a.wrong_count||1) || String(b.last_wrong_at||b.created_at||'').localeCompare(String(a.last_wrong_at||a.created_at||'')));
          } else if (WRONG_LIST_UI.sort === 'subject') {
            out.sort((a,b)=>String(a.subject||'').localeCompare(String(b.subject||''),'zh-Hans-CN') || String(b.last_wrong_at||b.created_at||'').localeCompare(String(a.last_wrong_at||a.created_at||'')));
          } else {
            out.sort((a,b)=>String(b.last_wrong_at||b.created_at||'').localeCompare(String(a.last_wrong_at||a.created_at||'')));
          }
          return out;
        };
        const getFiltered = () => {
          let items = allItems.filter(it => WRONG_LIST_UI.subject === 'all' ? true : String(it.subject||'') === WRONG_LIST_UI.subject);
          if (WRONG_LIST_UI.pendingOnly) items = items.filter(it => String(it.status||'') === 'pending');
          return applySort(items);
        };
        const renderPager = (totalPages) => {
          if (!pageListEl || !pagePrevBtn || !pageNextBtn) return;
          const cur = WRONG_LIST_UI.page;
          const mkBtn = (p, active=false) => `<button data-wl-page="${p}" class="size-9 text-xs font-bold rounded-lg flex items-center justify-center transition-all ${active ? 'bg-primary text-white' : 'text-slate-400 hover:bg-slate-100'}">${p}</button>`;
          const mkDot = () => `<span class="px-2 text-slate-300">...</span>`;
          const parts = [];
          if (totalPages <= 7) {
            for (let i=1;i<=totalPages;i++) parts.push(mkBtn(i, i===cur));
          } else {
            parts.push(mkBtn(1, cur===1));
            if (cur > 3) parts.push(mkDot());
            for (let i=Math.max(2, cur-1); i<=Math.min(totalPages-1, cur+1); i++) parts.push(mkBtn(i, i===cur));
            if (cur < totalPages-2) parts.push(mkDot());
            parts.push(mkBtn(totalPages, cur===totalPages));
          }
          pageListEl.innerHTML = parts.join('');
          pageListEl.querySelectorAll('[data-wl-page]').forEach(node => {
            node.onclick = () => {
              const p = Number(node.getAttribute('data-wl-page') || 1);
              if (!Number.isFinite(p)) return;
              WRONG_LIST_UI.page = Math.max(1, Math.min(totalPages, p));
              renderRows();
            };
          });
          const disabledCls = ['opacity-40','pointer-events-none'];
          pagePrevBtn.classList.toggle(disabledCls[0], cur <= 1);
          pagePrevBtn.classList.toggle(disabledCls[1], cur <= 1);
          pageNextBtn.classList.toggle(disabledCls[0], cur >= totalPages);
          pageNextBtn.classList.toggle(disabledCls[1], cur >= totalPages);
          pagePrevBtn.onclick = () => { if (WRONG_LIST_UI.page > 1) { WRONG_LIST_UI.page -= 1; renderRows(); } };
          pageNextBtn.onclick = () => { if (WRONG_LIST_UI.page < totalPages) { WRONG_LIST_UI.page += 1; renderRows(); } };
        };
        const renderRows = () => {
          const filteredItems = getFiltered();
          const pageSize = Math.max(1, Number(WRONG_LIST_UI.pageSize || 15));
          const totalPages = Math.max(1, Math.ceil(filteredItems.length / pageSize));
          if (WRONG_LIST_UI.page > totalPages) WRONG_LIST_UI.page = totalPages;
          if (WRONG_LIST_UI.page < 1) WRONG_LIST_UI.page = 1;
          const pageStart = (WRONG_LIST_UI.page - 1) * pageSize;
          const items = filteredItems.slice(pageStart, pageStart + pageSize);
          renderPager(totalPages);
          if (summaryEl) {
            const total = Array.isArray(allItems) ? allItems.length : Number(d.total || 0);
            summaryEl.textContent = `共 ${total} 条记录，当前筛选 ${filteredItems.length} 条，第 ${WRONG_LIST_UI.page}/${totalPages} 页`;
          }
          if (!filteredItems.length) {
            listWrap.innerHTML = '<div class="px-6 py-10 text-slate-400 text-sm">当前筛选下暂无错题</div>';
          } else if (WRONG_LIST_UI.groupByTopic) {
            const groups = {};
            items.forEach(it => {
              const k = String(it.topic || it.subject || '未分类').trim() || '未分类';
