function buildNav() {
  const nav = $id('tb-nav');
  if (!nav) return;
  nav.innerHTML = '';

  const SEC_ICONS = {
    '主控台':  'home',
    '知识宇宙':'hub',
    '学习中心':'school',
    '错题归因':'bug_report',
    '成长洞察':'insights',
    '家长端':  'supervised_user_circle',
    '会员中心':'workspace_premium',
