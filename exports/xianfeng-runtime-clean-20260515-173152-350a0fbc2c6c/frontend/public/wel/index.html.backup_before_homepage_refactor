      });
      wrap.appendChild(dd);

      // Smooth hover open/close via inline styles
      let _closeT = null;
      const _open = () => {
        clearTimeout(_closeT);
        // Close sibling dropdowns
        nav.querySelectorAll('.tb-nav-item').forEach(other => {
          if (other !== wrap) {
            const od = other.querySelector('.tb-dropdown');
            if (od) { od.style.opacity='0'; od.style.visibility='hidden'; od.style.transform='translateY(6px) scale(0.98)'; od.style.pointerEvents='none'; }
            other.classList.remove('dd-open');
            const oa = other.querySelector('.arr'); if (oa) oa.style.transform='';
          }
        });
        dd.style.opacity='1'; dd.style.visibility='visible';
        dd.style.transform='translateY(0) scale(1)'; dd.style.pointerEvents='all';
        wrap.classList.add('dd-open');
        const arr = wrap.querySelector('.arr'); if (arr) arr.style.transform='rotate(180deg)';
      };
      const _close = () => {
        _closeT = setTimeout(() => {
          dd.style.opacity='0'; dd.style.visibility='hidden';
          dd.style.transform='translateY(6px) scale(0.98)'; dd.style.pointerEvents='none';
          wrap.classList.remove('dd-open');
          const arr = wrap.querySelector('.arr'); if (arr) arr.style.transform='';
        }, 120);
      };
      wrap.addEventListener('mouseenter', _open);
      wrap.addEventListener('mouseleave', _close);
    }

    nav.appendChild(wrap);
  });

  // Close all dropdowns when clicking outside nav
  document.removeEventListener('click', _navOutsideClick);
  document.addEventListener('click', _navOutsideClick);

