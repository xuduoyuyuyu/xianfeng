async function analyzeContent() {
  const txt = $id('paste-text').value.trim();
  if(!txt && !currentUploadFile) return alert('请先输入或粘贴文件内容');
  
  $id('um-body').style.display = 'none';
  $id('um-footer').style.display = 'none';
  $id('analyzing-wrap').classList.add('show');
  $id('analyze-progress').textContent = '正在上传文件...';

  try {
    let contentToAnalyze = txt;
    let fileUrl = '';

    // 1. Upload File if exists
    if (currentUploadFile) {
        // Always upload to support "Open File"
        $id('analyze-progress').textContent = `正在上传文件 (${(currentUploadFile.size/1024).toFixed(1)}KB)...`;
        
        const res = await new Promise((resolve, reject) => {
          const xhr = new XMLHttpRequest();
          xhr.open('POST', '/api/upload');
          xhr.setRequestHeader('X-File-Name', encodeURIComponent(currentUploadFile.name));
          xhr.setRequestHeader('Content-Type', 'application/octet-stream');
          xhr.setRequestHeader('Authorization', `Bearer ${TOK}`);
          
          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              const pct = Math.round((e.loaded / e.total) * 100);
              $id('analyze-progress').textContent = `正在上传... ${pct}%`;
            }
          };
          
          xhr.onload = () => {
            if (xhr.status >= 200 && xhr.status < 300) {
              try { resolve(JSON.parse(xhr.responseText)); }
              catch(e) { reject(new Error('Invalid JSON response')); }
            } else {
              try {
                const err = JSON.parse(xhr.responseText);
                reject(new Error(err.error || `Upload failed ${xhr.status}`));
              } catch(e) {
                reject(new Error(`Upload failed ${xhr.status}`));
              }
            }
          };
          
          xhr.onerror = () => reject(new Error('Network error (Failed to fetch)'));
          xhr.send(currentUploadFile);
        });
        
        if (res.error) throw new Error(res.error);
        fileUrl = res.url;
        
        // Try extract text if supported
        let extra = '';
        if (/\.(txt|md|json|py|js|html|css|csv)$/i.test(currentUploadFile.name)) {
             try { extra = await currentUploadFile.text(); } catch(e){}
        } else {
             extra = '(暂不支持此格式的自动内容提取)';
        }
        contentToAnalyze = `[文件已上传] ${currentUploadFile.name}\nURL: ${fileUrl}\n\n${extra}`;
    }

    // 2. Create Textbook Record
    $id('analyze-progress').textContent = '正在创建知识库记录...';
    const tb = await api('POST', '/api/textbooks', {
      title: currentUploadFile ? currentUploadFile.name : '未命名上传内容',
      subject: '综合', // Can be detected later
      content_text: contentToAnalyze
    });

    // 3. Simulate Analysis Steps
    const steps = ['step-1','step-2','step-3','step-4'];
    const msgs = ['识别知识点 & 概念...','构建知识层级关系...','生成知识图谱节点...','标注重难点 & 考频...'];
    
    for(let i=0; i<steps.length; i++){
      const el = $id(steps[i]);
      $id('analyze-progress').textContent = msgs[i];
      if(el) el.classList.add('active');
      await new Promise(r=>setTimeout(r, 600 + Math.random()*800));
      if(el) { el.classList.remove('active'); el.classList.add('done'); }
    }
    
    // 4. Trigger Real Analysis (Async)
    try {
        await api('POST', `/api/textbooks/${tb.id}/analyze`);
    } catch (e) {
        console.warn('Backend analysis trigger failed:', e);
        // 不阻断流程，因为可能是超时，后端可能仍在处理
    }

    setTimeout(() => {
      hideUpload();
      toast('AI 解析完成！知识图谱已更新 ✨');
      // Refresh current page
      if(curId === 3 || curId === 0) { // Resource Center or Dashboard
         // Reload logic if needed
      }
      // Broadcast to iframe
      const frame = FR[curId];
      if(frame && frame.contentWindow && frame.contentWindow.onAIParseDone) {
        frame.contentWindow.onAIParseDone();
      }
    }, 500);

  } catch(e) {
    alert('上传或解析失败: ' + e.message);
    showUpload(); // Reset
  }
}

