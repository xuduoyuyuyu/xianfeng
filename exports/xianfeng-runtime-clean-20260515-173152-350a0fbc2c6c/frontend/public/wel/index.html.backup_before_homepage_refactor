// ─── BRIDGE: 成长报告 (page 21) ──────────
function bridge_growthReport(w) {
  if (w.__growthBridgeLock) return;
  w.__growthBridgeLock = true;
  fetchReportCached('/api/reports/growth', 90000).then(d=>{
    try {
      const doc = w.document;
      const growthRoot = doc.querySelector('main');
      if (!growthRoot) return;
      const esc = (s='') => String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
      const gradeText = String(d.user?.grade || '').trim() || '未知年级';
      const mainHeading = doc.querySelector('h1');
      if (mainHeading) mainHeading.textContent = '综合分析';
      const bySubject = {};
      (d.subject_mastery || []).forEach(x => { bySubject[String(x.subject||'').trim()] = Number(x.avg||0); });
      const mapAlias = {'数学':'数学','科学':'科学','逻辑':'逻辑','言语':'言语','记忆':'记忆','语文':'言语','英语':'言语','物理':'科学','化学':'科学','生物':'科学'};
      const getSM = (s) => {
        const key = mapAlias[s] || s;
        if (bySubject[key] != null) return bySubject[key];
        const direct = Object.keys(bySubject).find(k => (k||'').includes(s) || s.includes(k));
        return direct ? bySubject[direct] : 0;
      };
      const avgMastery = (d.subject_mastery || []).length ? Math.round((d.subject_mastery || []).reduce((s,x)=>s+Number(x.avg||0),0)/(d.subject_mastery||[]).length) : 0;
      const peerAvg = Math.max(0, Math.min(99, avgMastery - 8));
      const titleP = [...doc.querySelectorAll('p')].find(el => (el.textContent||'').includes('深度分析对象'));
      if (titleP) titleP.innerHTML = `深度分析对象：<span class="font-semibold text-primary">${esc(d.user?.name || '学生')}</span> • ${esc(gradeText)}`;
      const ringValue = [...doc.querySelectorAll('span')].find(el => /^\d+%$/.test((el.textContent||'').trim()) && el.className.includes('text-6xl'));
      if (ringValue) ringValue.textContent = `${avgMastery}%`;
      const trendSubEl = [...doc.querySelectorAll('p')].find(el => (el.textContent||'').includes('对比上次评估'));
      let trendEl = null;
      if (trendSubEl && trendSubEl.parentElement) {
        trendEl = [...trendSubEl.parentElement.querySelectorAll('p')].find(x => x !== trendSubEl) || null;
      }
      if (!trendEl) trendEl = [...doc.querySelectorAll('p')].find(el => /提升了|回落了|持平/.test(el.textContent||''));
      let overallTrend = { html: '', className: '', subText: '' };
      if (trendEl) {
        const hist = Array.isArray(d.assessment_history) ? d.assessment_history : [];
        const getTs = (x) => new Date(x?.completed_at || x?.created_at || x?.taken_at || x?.date || '').getTime();
        const sortedHist = [...hist].sort((a,b) => (getTs(b) || 0) - (getTs(a) || 0));
        let delta = 0;
        if (sortedHist.length >= 2) delta = Number(sortedHist[0]?.score || 0) - Number(sortedHist[1]?.score || 0);
        else if (sortedHist.length === 1) delta = Number(avgMastery || 0) - Number(sortedHist[0]?.score || 0);
        const flat = Math.abs(delta) < 0.05;
        const up = delta > 0;
        const verb = flat ? '持平' : (up ? '提升了' : '回落了');
        const icon = flat ? 'trending_flat' : (up ? 'trending_up' : 'trending_down');
        trendEl.innerHTML = `<span class="material-symbols-outlined text-sm">${icon}</span>${verb} ${Math.abs(delta).toFixed(1)}%`;
        trendEl.className = `${flat ? 'text-slate-500' : (up ? 'text-emerald-500' : 'text-rose-500')} font-bold flex items-center justify-center gap-1`;
        overallTrend.html = trendEl.innerHTML;
        overallTrend.className = trendEl.className;
        if (trendSubEl) {
          const ref = sortedHist.length >= 2 ? sortedHist[1] : (sortedHist[0] || null);
          const ts = ref ? new Date(getTs(ref)) : null;
          const ym = (ts && Number.isFinite(ts.getTime())) ? `${ts.getFullYear()}年${ts.getMonth()+1}月` : '';
          trendSubEl.textContent = ym ? `对比上次评估 (${ym})` : '对比上次评估';
          overallTrend.subText = trendSubEl.textContent || '';
        }
      }
      const renderSubjectTrend = (label, cur) => {
        if (!trendEl) return;
        const diff = Number(cur || 0) - Number(peerAvg || 0);
        const flat = Math.abs(diff) < 0.05;
        const up = diff > 0;
        const icon = flat ? 'trending_flat' : (up ? 'trending_up' : 'trending_down');
        const text = flat ? '与同伴持平' : (up ? '高于同伴' : '低于同伴');
        trendEl.innerHTML = `<span class="material-symbols-outlined text-sm">${icon}</span>${text} ${Math.abs(diff).toFixed(1)}%`;
        trendEl.className = `${flat ? 'text-slate-500' : (up ? 'text-emerald-500' : 'text-rose-500')} font-bold flex items-center justify-center gap-1`;
        if (trendSubEl) trendSubEl.textContent = `${label}学科 · 实时渲染`;
      };
      const restoreOverallTrend = () => {
        if (trendEl && overallTrend.html) {
          trendEl.innerHTML = overallTrend.html;
          trendEl.className = overallTrend.className;
        }
        if (trendSubEl && overallTrend.subText) trendSubEl.textContent = overallTrend.subText;
      };
      const ringCircle = doc.querySelector('circle.text-primary.drop-shadow-\\[0_0_15px_rgba\\(127\\,19\\,236\\,0\\.4\\)\\]');
      if (ringCircle) {
        const total = 691;
        ringCircle.setAttribute('stroke-dasharray', String(total));
        ringCircle.setAttribute('stroke-dashoffset', String(Math.round(total * (1 - avgMastery/100))));
      }
      let masteryAnimToken = 0;
      const animateMastery = (target, fromZero = false) => {
        const ringValEl = ringValue;
        if (!ringValEl || !ringCircle) return;
        masteryAnimToken += 1;
        const token = masteryAnimToken;
        const end = Math.max(0, Math.min(100, Math.round(Number(target || 0))));
        const start = fromZero ? 0 : Number((ringValEl.textContent || '').replace('%','')) || 0;
        const duration = 520;
        const total = 691;
        const t0 = performance.now();
        const step = (now) => {
          if (token !== masteryAnimToken) return;
          const p = Math.min(1, (now - t0) / duration);
          const e = 1 - Math.pow(1 - p, 3);
          const v = Math.round(start + (end - start) * e);
          ringValEl.textContent = `${v}%`;
          ringCircle.setAttribute('stroke-dashoffset', String(Math.round(total * (1 - v/100))));
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };
      const barGroups = [...doc.querySelectorAll('div.flex.flex-col.gap-3.items-center.group')];
      const firstReportSection = growthRoot.querySelector('section');
