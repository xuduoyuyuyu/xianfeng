      doc.querySelectorAll('[class*="text-lg"],[class*="leading-relaxed"]').forEach(el => {
        if (el.textContent.length > 15 && !el.querySelector('button'))
          el.textContent = wItem.question.substring(0,100)+(wItem.question.length>100?'...':'');
