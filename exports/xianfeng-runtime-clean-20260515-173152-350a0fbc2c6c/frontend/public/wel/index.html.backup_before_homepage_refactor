      if (leftStatCol && rightBarsCol) {
        if (rightBarsCol.parentNode && rightBarsCol.parentNode === leftStatCol.parentNode) {
          rightBarsCol.parentNode.insertBefore(rightBarsCol, leftStatCol);
        }
        const targetH = Math.max(260, Math.round(leftStatCol.getBoundingClientRect().height));
        rightBarsCol.style.height = `${targetH}px`;
        rightBarsCol.style.minHeight = `${targetH}px`;
        barGroups.forEach(g => {
          g.style.height = '100%';
          g.style.justifyContent = 'space-between';
          const label = g.querySelector('span.text-xs');
          const shell = g.querySelector('div[class*="h-[180px]"]');
          if (label && shell) {
            const labelH = Math.ceil(label.getBoundingClientRect().height || 16);
            shell.style.height = `${Math.max(120, targetH - labelH - 12)}px`;
          }
        });
      }
      const subjectDisplay = (d.subject_mastery || [])
        .map(x => ({ subject: String(x.subject || '').trim(), avg: Math.round(Number(x.avg || 0)) }))
        .filter(x => x.subject)
        .sort((a,b)=>b.avg-a.avg);
      barGroups.forEach(g => {
        const labelEl = g.querySelector('span.text-xs');
        const fallback = (labelEl?.textContent || '').trim();
        const mapped = subjectDisplay.shift();
        const label = mapped?.subject || fallback;
        if (labelEl) labelEl.textContent = label;
        const cur = mapped ? Math.round(Number(mapped.avg || 0)) : Math.round(getSM(label));
        const bgBars = g.querySelectorAll('div[class*="bg-primary/20"]');
        const fgBar = g.querySelector('div[class*="bg-primary rounded-t-md"]');
        if (bgBars[0]) bgBars[0].style.height = `${Math.max(8, peerAvg)}%`;
        if (fgBar) fgBar.style.height = `${Math.max(5,cur)}%`;
        g.style.cursor = 'pointer';
        g.onmouseenter = () => { animateMastery(cur, true); renderSubjectTrend(label, cur); };
        g.onmouseleave = () => { animateMastery(avgMastery, true); restoreOverallTrend(); };
        g.onclick = () => {
          applySubjectFilter(label);
          renderSubjectTrend(label, cur);
        };
      });
      const starSection = [...doc.querySelectorAll('section')].find(sec => {
        const h2 = sec.querySelector('h2');
        return (h2 && String(h2.textContent || '').includes('知识星图'));
