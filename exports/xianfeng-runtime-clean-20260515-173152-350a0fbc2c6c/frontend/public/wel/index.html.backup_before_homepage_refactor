                <div class="col-span-1 text-[11px] text-slate-400 text-center">${date}</div>
                <div class="col-span-2 flex justify-end gap-2.5 flex-wrap"><button data-wid-ai="${it.id}" class="ai-attribution-btn"><span class="material-symbols-outlined text-sm !font-bold">bolt</span>AI 深度归因</button><button data-wid-rp="${it.id}" class="core-repair-btn"><span class="material-symbols-outlined text-sm !font-bold">diamond</span>点击修复</button></div>
              </div>`;
            });
