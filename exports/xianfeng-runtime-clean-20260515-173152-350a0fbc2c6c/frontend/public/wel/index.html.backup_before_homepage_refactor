function bridge_wrongDetail(w) {
  api('GET','/api/wrongs').then(d=>{
    try {
      const doc = w.document;
      const ws = d.items;
      if (!ws.length) return;
      const wItem = curWrongId ? ws.find(x=>x.id==curWrongId) || ws[0] : ws[0];
      curWrongId = wItem.id;
      const unresolvedOrdered = [...ws]
        .filter(x => String(x.status || '') !== 'repaired')
        .sort((a,b)=>String(b.last_wrong_at || b.created_at || '').localeCompare(String(a.last_wrong_at || a.created_at || '')));
      const curUnresolvedIdx = unresolvedOrdered.findIndex(x => Number(x.id || 0) === Number(wItem.id || 0));
      const hasNextUnrepaired = curUnresolvedIdx >= 0 && curUnresolvedIdx < unresolvedOrdered.length - 1;
      const pickTextBlock = () => doc.querySelector('.bg-white\\/50') || doc.querySelector('[class*="leading-relaxed"]');
      const textBlock = pickTextBlock();
      if (textBlock) {
        textBlock.innerHTML = '<p class="mb-2 ai-pulse">正在加载题目完整内容...</p>';
        const esc = (s='') => String(s || '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
        const renderWrongQuestionContent = (full) => {
          const qRaw = String(full?.question || wItem.question || '').replace(/\r\n?/g, '\n');
          const opts = Array.isArray(full?.options) ? full.options : [];
          const img = String(full?.question_image || '').trim();
          const svg = String(full?.svg || '').trim();
          textBlock.innerHTML = `
            <div class="w-full text-left space-y-4">
              <div id="wd-question-main" class="text-slate-700 text-base leading-relaxed font-normal"></div>
              ${img || svg ? `<div id="wd-visual" class="mt-1"></div>` : ''}
              ${opts.length ? `<div class="space-y-1.5 text-sm text-slate-700" id="wd-options"></div>` : ''}
            </div>`;
          const qMain = textBlock.querySelector('#wd-question-main');
          if (qMain) renderRichMath(qMain, qRaw);
          const optWrap = textBlock.querySelector('#wd-options');
          if (optWrap) {
            opts.forEach((o, i) => {
              const item = doc.createElement('div');
              item.className = 'py-0.5';
              item.textContent = `${['A','B','C','D','E','F','G','H'][i] || (i+1)}. ${String(o || '').replace(/^[A-H1-9][\.\):、\s]*/i, '').trim()}`;
              optWrap.appendChild(item);
            });
          }
          const visualHost = textBlock.querySelector('#wd-visual');
          if (visualHost) renderGeometryComponent(visualHost, { image_url: img, svg: sanitizeRichMathHtml(svg) }, { theme: 'wrong', title: '几何图形高保真还原区域' });
        };
        api('GET', `/api/wrongs/${wItem.id}/content`).then(renderWrongQuestionContent).catch(() => renderWrongQuestionContent({ question: wItem.question || '' }));
      }
      const userAnsEl = doc.querySelector('[data-wrong-answer]');
      const corrAnsEl = doc.querySelector('[data-correct-answer]');
      if (userAnsEl) userAnsEl.textContent = String(wItem.student_answer || '未作答');
      if (corrAnsEl) corrAnsEl.textContent = String(wItem.correct_answer || '暂无');
      const title = doc.querySelector('h1');
      if (title) title.textContent = `题目 #W-${wItem.id} 详情`;
      const tag = doc.querySelector('.bg-blue-50');
      if (tag) tag.textContent = wItem.subject || '未分类';
      const timeEl = [...doc.querySelectorAll('span')].find(el => (el.textContent || '').includes('录入于'));
      if (timeEl) timeEl.textContent = `录入于 ${String(wItem.last_wrong_at || wItem.created_at || '').slice(0,16).replace('T',' ')}`;
      const cardsAll = [...doc.querySelectorAll('.glass-card')];
      const coreCard = cardsAll.find(x => (x.textContent || '').includes('核心原理解析'));
      const pitCard = cardsAll.find(x => (x.textContent || '').includes('AI 避坑指南'));
      const coreP = coreCard ? coreCard.querySelector('p') : null;
      const pitUl = pitCard ? pitCard.querySelector('ul') : null;
      if (coreP) coreP.innerHTML = `<span class="ai-pulse">正在生成并保存「核心原理解析」...</span>`;
      if (pitUl) pitUl.innerHTML = `<li class="text-xs text-slate-500 ai-pulse">正在生成并保存「AI 避坑指南」...</li>`;
      api('GET', `/api/wrongs/${wItem.id}/insights`).then(ins => {
        const core = String(ins.core_principle || '').trim();
        const pits = Array.isArray(ins.pitfall_items) ? ins.pitfall_items : String(ins.pitfall_guide || '').split(/\n+/).map(s=>s.trim()).filter(Boolean);
        if (coreP) coreP.textContent = core || '暂无解析';
        if (pitUl) {
          if (!pits.length) {
            pitUl.innerHTML = '<li class="text-xs text-slate-500">暂无易错点</li>';
          } else {
            pitUl.innerHTML = pits.slice(0,6).map(x=>`<li class="flex items-start gap-2"><span class="size-1.5 bg-primary rounded-full mt-1"></span><span>${String(x).slice(0,80)}</span></li>`).join('');
          }
        }
      }).catch(() => {
        if (coreP) coreP.textContent = '解析加载失败';
        if (pitUl) pitUl.innerHTML = '<li class="text-xs text-slate-500">易错点加载失败</li>';
      });
      const ensureAI = async () => {
        const old = String(wItem.ai_analysis || '').trim();
        const invalidOld = old && (old.includes('【无AI分析】') || old.includes('请配置 ANTHROPIC_API_KEY') || old.includes('请配置 VOLC_API_KEY'));
        if (old && !invalidOld) return old;
        try {
          const r = await api('POST', `/api/wrongs/${wItem.id}/analyze`);
          return r.ai_analysis || '';
        } catch {
          return old || '';
        }
      };
      ensureAI().then(ai => {
        const txt = String(ai || wItem.repeat_analysis || '').trim();
        if (!txt) return;
        const lines = txt.split('\n').map(s=>s.trim()).filter(Boolean);
        const cards = doc.querySelectorAll('.flex.gap-4 .flex-1.pb-4');
        cards.forEach((card, idx) => {
          const t = lines[idx] || lines[0] || txt;
          const p = card.querySelector('p');
          if (p) p.textContent = t.slice(0,120);
        });
        if (coreP && !String(coreP.textContent || '').trim()) coreP.textContent = (lines[0] || txt).slice(0,180);
        if (pitUl && pitUl.children.length <= 1) {
          pitUl.innerHTML = (lines.slice(1,3).map(x=>`<li class="flex items-start gap-2"><span class="size-1.5 bg-primary rounded-full mt-1"></span><span>${x.slice(0,56)}</span></li>`).join('')) || pitUl.innerHTML;
        }
      });
      const masteryEl = doc.querySelector('[data-hud-mastery]');
      const barEl = doc.querySelector('[data-hud-bar]');
      const topicEl = doc.querySelector('[data-hud-topic]');
      if (topicEl) topicEl.textContent = `知识点：${String(wItem.topic || wItem.subject || '未标注').trim().slice(0,36) || '未标注'}`;
      const fallbackMastery = Math.max(8, Math.min(96, Math.round(46 + (Number(wItem.repair_count || 0) * 11) - (Math.max(0, Number(wItem.wrong_count || 1) - 1) * 5))));
      if (masteryEl) masteryEl.textContent = `${fallbackMastery}%`;
      if (barEl) barEl.style.width = `${fallbackMastery}%`;
      api('GET', `/api/wrongs/${wItem.id}/mastery`).then(ms => {
        const acc = Number(ms?.accuracy);
        if (!Number.isFinite(acc)) return;
        const v = Math.max(0, Math.min(100, Math.round(acc)));
        if (masteryEl) masteryEl.textContent = `${v}%`;
        if (barEl) barEl.style.width = `${v}%`;
        if (topicEl) {
          const t = String(ms?.topic || wItem.topic || wItem.subject || '未标注').trim().slice(0,36) || '未标注';
          topicEl.textContent = `知识点：${t}`;
        }
      }).catch(()=>{});
      const fixWrap = doc.querySelector('[data-fix-wrap]');
      const scrollBox = doc.querySelector('[data-wrong-scroll]');
      if (fixWrap && scrollBox) {
        if (scrollBox._wrongDetailOnScroll) scrollBox.removeEventListener('scroll', scrollBox._wrongDetailOnScroll);
        scrollBox._wrongDetailOnScroll = null;
        fixWrap.classList.remove('is-collapsed');
      }
      const selected = new Set();
      try {
        const arr = JSON.parse(wItem.reflection_tags || '[]');
        if (Array.isArray(arr)) arr.forEach(x => selected.add(String(x)));
      } catch {}
      const noteEl = doc.querySelector('[data-reflect-note]');
      const historyWrap = doc.querySelector('[data-reflect-history]');
      const historyList = doc.querySelector('[data-reflect-history-list]');
      const editorWrap = doc.querySelector('[data-reflect-editor]');
      const hudPanel = doc.querySelector('.hud-panel');
      const inlineSaveTimers = {};
      const historyKey = `wel_reflect_history_${wItem.id}`;
      const parseHistory = () => {
        try {
          const raw = localStorage.getItem(historyKey) || '[]';
          const arr = JSON.parse(raw);
          if (!Array.isArray(arr)) return [];
          return arr.map(x => ({
            note: String(x?.note || '').trim().slice(0,800),
            ts: Number(x?.ts || 0) || Date.now()
          })).filter(x => x.note);
        } catch { return []; }
      };
      let reflectHistory = parseHistory();
      const seedNote = String(wItem.reflection_note || '').trim();
      if (seedNote) {
        const has = reflectHistory.some(x => String(x.note || '') === seedNote);
        if (!has) reflectHistory.unshift({ note: seedNote, ts: Date.now() - 1 });
      }
      reflectHistory = reflectHistory.slice(0,3);
      const persistHistory = () => {
        try { localStorage.setItem(historyKey, JSON.stringify(reflectHistory.slice(0,3))); } catch {}
      };
      const syncReflectEditor = () => {
        if (!editorWrap) return;
        const hide = reflectHistory.length >= 3;
        editorWrap.style.display = hide ? 'none' : '';
        if (hudPanel) hudPanel.classList.toggle('reflect-compact', hide);
      };
      const persistCurrentReflection = async (noteVal, silent=false) => {
        const v = String(noteVal || '').trim();
        if (!v) return false;
        await api('POST', `/api/wrongs/${wItem.id}/reflection`, { tags: [...selected], note: v });
        const entry = { note: v, ts: Date.now() };
        reflectHistory = [entry, ...reflectHistory.filter(x => String(x.note || '') !== v)].slice(0,3);
        persistHistory();
        renderReflectHistory();
        if (noteEl) noteEl.value = '';
        if (!silent) toast('归因已保存');
        return true;
      };
      const renderReflectHistory = () => {
        if (!historyWrap || !historyList) return;
        if (!reflectHistory.length) {
          historyWrap.classList.add('hidden');
          historyList.innerHTML = '';
          syncReflectEditor();
          return;
        }
        historyWrap.classList.remove('hidden');
        historyList.innerHTML = reflectHistory.map((x, i) => {
          const note = x.note ? `<div data-reflect-inline-index="${i}" contenteditable="true" spellcheck="false" class="text-[11px] text-slate-600 leading-snug break-words whitespace-pre-wrap outline-none min-h-[18px]">${escapeHtmlText(x.note)}</div>` : '';
          return `<div class="rounded-lg border border-primary/10 bg-white/70 px-2.5 py-1.5 hover:border-primary/30 transition-all">${note}</div>`;
        }).join('');
        historyList.querySelectorAll('[data-reflect-inline-index]').forEach(item => {
          const i = Number(item.getAttribute('data-reflect-inline-index') || -1);
          if (i < 0 || i >= reflectHistory.length) return;
          const saveInline = async (silent=true) => {
            const val = String(item.textContent || '').trim();
            if (!val) {
              item.textContent = String(reflectHistory[i]?.note || '');
              return;
            }
            reflectHistory[i] = { note: val, ts: Date.now() };
            persistHistory();
            try {
              await api('POST', `/api/wrongs/${wItem.id}/reflection`, { tags: [...selected], note: val });
              if (!silent) toast('已自动保存');
            } catch {}
          };
          item.oninput = () => {
            if (inlineSaveTimers[i]) clearTimeout(inlineSaveTimers[i]);
            inlineSaveTimers[i] = setTimeout(() => saveInline(true), 450);
          };
          item.onblur = () => {
            if (inlineSaveTimers[i]) clearTimeout(inlineSaveTimers[i]);
            saveInline(true).catch(()=>{});
          };
        });
        syncReflectEditor();
      };
      persistHistory();
      renderReflectHistory();
      if (noteEl) noteEl.value = '';
      const tagBtns = [...doc.querySelectorAll('[data-reflect-tag]')];
      const syncTagStyle = () => {
        tagBtns.forEach(btn => {
          const name = btn.getAttribute('data-reflect-tag') || '';
          const on = selected.has(name);
          btn.style.background = on ? 'rgba(127,19,236,.12)' : '';
          btn.style.borderColor = on ? 'rgba(127,19,236,.5)' : '';
          btn.style.color = on ? '#7f13ec' : '';
        });
      };
      tagBtns.forEach(btn => btn.onclick = (e) => {
        e.preventDefault();
        const name = btn.getAttribute('data-reflect-tag') || '';
        if (!name) return;
        if (selected.has(name)) selected.delete(name); else selected.add(name);
        syncTagStyle();
      });
      syncTagStyle();
      const saveBtn = doc.querySelector('[data-reflect-save]');
      if (saveBtn) {
        saveBtn.onclick = async (e) => {
          e.preventDefault();
          saveBtn.disabled = true;
          saveBtn.textContent = '保存中...';
          try {
            const noteVal = noteEl ? String(noteEl.value || '').trim() : '';
            if (!noteVal) { toast('请输入归因文本后再保存','info'); return; }
            await persistCurrentReflection(noteVal, false);
          } catch (err) {
            toast(err.message || '保存失败','err');
          } finally {
            saveBtn.disabled = false;
            saveBtn.textContent = '保存归因结果';
            syncReflectEditor();
          }
        };
      }
      doc.querySelectorAll('button').forEach(btn => {
        const t = (btn.textContent || '').trim();
        if (btn.getAttribute('data-back-center') === '1') {
          btn.onclick = (e) => { e.preventDefault(); go(16); };
          return;
        }
        if (btn.getAttribute('data-next-repair') !== null) {
          btn.disabled = !hasNextUnrepaired;
          btn.style.opacity = hasNextUnrepaired ? '' : '.5';
          btn.style.cursor = hasNextUnrepaired ? '' : 'not-allowed';
          btn.onclick = (e) => {
            e.preventDefault();
            if (!hasNextUnrepaired) { toast('没有下一道未修复错题了','info'); return; }
            const nextItem = unresolvedOrdered[curUnresolvedIdx + 1] || null;
            if (!nextItem) { toast('没有下一道未修复错题了','info'); return; }
            curWrongId = nextItem.id;
            go(18);
          };
          return;
        }
        if (t.includes('返回中心')) btn.onclick = (e) => { e.preventDefault(); go(16); };
        if (t.includes('立即开始修复') || t.includes('立即修复')) btn.onclick = (e) => { e.preventDefault(); go(20); };
      });
    } catch(e) { console.warn('wrongDetail bridge', e); }
  }).catch(()=>{});
}

// ─── BRIDGE: AI归因诊断 (page 19) ─────────
function bridge_wrongAI(w) {
  api('GET','/api/wrongs').then(async d=>{
    try {
      const doc = w.document;
      const pending = d.items.filter(x=>x.status==='pending');
      const wItem = curWrongId ? d.items.find(x=>x.id==curWrongId) || pending[0] : pending[0];
