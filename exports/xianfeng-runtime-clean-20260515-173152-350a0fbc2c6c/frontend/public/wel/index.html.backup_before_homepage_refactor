      const dd = document.createElement('div');
      dd.className = 'tb-dropdown';
      // Use inline styles for reliable show/hide (bypasses any display:none cascade)
      Object.assign(dd.style, {
        display:'block', position:'absolute', top:'100%', left:'0',
        minWidth:'185px', background:'var(--sf)', border:'1px solid var(--brd)',
