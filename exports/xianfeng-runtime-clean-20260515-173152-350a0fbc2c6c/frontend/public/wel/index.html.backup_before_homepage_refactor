function getCurrentAssessQuestionIndex(total=3){
  const t = Math.max(1, Number(total || 3));
  const idx = Number(curAssessQIdx || 0);
  if (!Number.isFinite(idx) || idx < 0) return 0;
  return idx >= t ? (t - 1) : idx;
}

function injectBoardQuestion(doc, q, qIdx, total){
  if(!doc || !q) return;
  const totalSafe = Math.max(1, Number(total || 1));
  const idxSafe = Math.max(0, Number(qIdx || 0));
  const qp = doc.getElementById('board-q-progress');
  if (qp) qp.textContent = `第 ${idxSafe + 1} / ${totalSafe} 题`;
  const bs = doc.getElementById('board-subject');
  if (bs) bs.textContent = q.subject || '综合';
  const bk = doc.getElementById('board-book');
  if (bk) bk.textContent = q.source === 'bank' ? `后台题库联调 · 题目ID ${q.question_id || '—'}` : 'AI生成题目';
  const kp = doc.getElementById('board-kp');
  if (kp) kp.textContent = q.kp || '未标注知识点';
  const qEl = doc.getElementById('board-question');
  if (qEl) renderRichMath(qEl, q.q || '');
  const grid = qEl ? qEl.parentElement?.querySelector('.grid') : null;
  if (grid && Array.isArray(q.opts) && q.opts.length){
    const btns = [...grid.querySelectorAll('button')];
    q.opts.slice(0, 4).forEach((opt, i) => {
      const b = btns[i];
      if(!b) return;
      const textNode = b.querySelector('span:last-child');
      if (textNode) renderRichMath(textNode, String(opt || '').replace(/^[A-D][\.\):、\s]*/i, ''));
      b.dataset.optLetter = ['A','B','C','D'][i];
      b.dataset.optRaw = String(opt || '');
    });
  }
}

function bridge_assessBoard(w){
