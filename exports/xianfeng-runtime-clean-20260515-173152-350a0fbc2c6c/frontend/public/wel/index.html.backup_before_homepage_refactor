              const source = esc(it.source || '测评自动入库');
              const date = String(it.last_wrong_at || it.created_at || '').slice(0,10) || '-';
              const cnt = Number(it.wrong_count || 1);
              const tag = cnt > 1 ? `<span class="knowledge-tag">累计错 ${cnt} 次</span>` : '';
              const reasonTags = Array.isArray(it.reason_tags) ? it.reason_tags.map(x=>String(x||'').trim()).filter(Boolean) : [];
              const reasonShow = reasonTags.slice(0, 2).map(t=>`<span class="px-2 py-0.5 rounded-full border border-primary/20 bg-primary/5 text-primary text-[10px] max-w-[110px] truncate" title="${esc(t)}">${esc(t)}</span>`).join('');
              const reasonMore = reasonTags.length > 2 ? `<span class="text-[10px] text-slate-400">+${reasonTags.length-2}</span>` : '';
              const bind = esc(it.textbook_binding || '');
              html += `<div class="grid grid-cols-12 gap-4 px-6 py-5 items-start list-row" data-wid-open="${it.id}">
                <div class="col-span-2"><span class="px-2 py-1 bg-blue-50 text-blue-600 text-[10px] font-bold rounded border border-blue-100">${source}</span></div>
                <div class="col-span-3"><p class="text-sm text-slate-700 font-medium truncate pr-4" title="${q}" style="cursor:pointer">${q}</p>${bind?`<div class="mt-1 text-[10px] text-slate-400 truncate" title="${bind}">${bind}</div>`:''}</div>
                <div class="col-span-2"><div class="flex flex-wrap gap-2"><span class="knowledge-tag">${esc(it.subject || '未分类')}</span>${tag}</div></div>
