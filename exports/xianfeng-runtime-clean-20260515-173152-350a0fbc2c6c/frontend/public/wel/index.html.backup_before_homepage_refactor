<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>wel</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--p:#6c27d6;--pg:rgba(108,39,214,.2);--pd:rgba(108,39,214,.09);
  --bg:#f4f4f7;--sf:#fff;--brd:rgba(0,0,0,.07);--tx:#111118;--mu:#6b7280;--mu2:#9ca3af;
  --sb:0px;--tb:52px;--cl:#2563eb;--cg:#059669;--cr:#dc2626;--ca:#d97706;--cpr:#7c3aed}
html,body{height:100%;overflow:hidden;font-family:'DM Sans','Noto Sans SC',sans-serif;font-size:13px;color:var(--tx);-webkit-font-smoothing:antialiased;background:var(--bg)}
button{cursor:pointer;font:inherit}
.ms{font-family:'Material Symbols Rounded';font-variation-settings:'FILL' 1;line-height:1;vertical-align:middle}
.ms0{font-variation-settings:'FILL' 0}
/* AUTH */
#auth{position:fixed;inset:0;z-index:300;background:linear-gradient(135deg,#0f0a1e,#1a0e3a,#0d0d18);display:none;align-items:center;justify-content:center}
#auth.show{display:flex}
.auth-box{width:420px;padding:0 24px}
.auth-brand{display:flex;align-items:center;gap:10px;justify-content:center;margin-bottom:36px}
.auth-gem{width:34px;height:34px;background:var(--p);border-radius:9px;display:flex;align-items:center;justify-content:center}
.auth-gem svg{width:17px;height:17px;fill:white}
.auth-title{font-size:22px;font-weight:700;color:white;letter-spacing:-.4px}
.auth-title sup{font-size:12px;color:#a78bfa;vertical-align:super}
.auth-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:28px;backdrop-filter:blur(20px)}
.auth-tabs{display:flex;gap:3px;background:rgba(0,0,0,.25);border-radius:10px;padding:3px;margin-bottom:24px}
.atab{flex:1;padding:8px;border:none;border-radius:8px;background:transparent;font-size:13px;font-weight:500;color:rgba(255,255,255,.4);transition:all .15s}
.atab.on{background:var(--p);color:white;font-weight:600}
.afield{margin-bottom:13px}
.afield label{display:block;font-size:10px;font-weight:700;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.afield input,.afield select{width:100%;padding:10px 13px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:9px;color:white;font-size:13.5px;outline:none;transition:border-color .15s}
.afield input::placeholder{color:rgba(255,255,255,.25)}
.afield input:focus,.afield select:focus{border-color:var(--p)}
.afield select option{background:#1a0e3a}
.a2col{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.abtn{width:100%;padding:12px;background:var(--p);border:none;border-radius:10px;color:white;font-size:13.5px;font-weight:700;margin-top:6px;box-shadow:0 3px 16px var(--pg);transition:all .15s}
.abtn:hover{transform:translateY(-1px)}
.aerr{color:#f87171;font-size:11.5px;text-align:center;margin-top:6px;min-height:16px}
.ahint{text-align:center;color:rgba(255,255,255,.25);font-size:11.5px;margin-top:12px}
.pmask{position:fixed;inset:0;background:rgba(10,10,20,.45);backdrop-filter:blur(6px);z-index:9200;display:none;align-items:center;justify-content:center}
.pmask.show{display:flex}
.pcard{width:min(560px,92vw);background:#fff;border:1px solid var(--brd);border-radius:16px;box-shadow:0 16px 50px rgba(0,0,0,.2);overflow:hidden}
.phd{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--brd)}
.pttl{font-size:14px;font-weight:700}
.pbd{padding:14px 16px}
.pava-top{display:flex;align-items:center;gap:12px;padding:4px 0 12px}
.pava-preview{width:64px;height:64px;border-radius:16px;border:1px solid var(--brd);background:linear-gradient(135deg,var(--p),#a855f7);display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;font-weight:800;overflow:hidden;flex-shrink:0}
.pava-actions{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.pava-btn{padding:7px 12px;border:1px solid var(--brd);border-radius:999px;background:#fff;font-size:12px;font-weight:700;color:var(--mu);cursor:pointer;transition:all .12s}
.pava-btn:hover{border-color:var(--p);color:var(--p);background:var(--pd)}
.pava-tip{font-size:10px;color:var(--mu2)}
.prow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.pfield{margin-bottom:10px}
.pfield label{display:block;font-size:10px;font-weight:700;color:var(--mu2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.pfield input,.pfield select{width:100%;padding:9px 11px;border:1px solid var(--brd);border-radius:9px;background:#fff;font-size:13px;outline:none}
.pfield input:focus,.pfield select:focus{border-color:var(--p)}
.pft{display:flex;justify-content:flex-end;gap:8px;padding:12px 16px;border-top:1px solid var(--brd)}
.pbtn{border:1px solid var(--brd);background:#fff;color:var(--tx);padding:8px 13px;border-radius:8px;font-size:12px;font-weight:600}
.pbtn.pri{background:var(--p);color:#fff;border-color:var(--p)}
/* APP */
#app{position:fixed;inset:0;display:none;flex-direction:column}
#app.on{display:flex}
#tb{height:var(--tb);flex-shrink:0;background:var(--sf);border-bottom:1px solid var(--brd);display:flex;align-items:center;z-index:100;padding:0;gap:0;overflow:visible}
.tb-logo{flex-shrink:0;display:flex;align-items:center;gap:8px;padding:0 18px 0 16px;cursor:pointer;transition:background .15s;height:100%;border-right:1px solid var(--brd)}
.tb-logo:hover{background:rgba(108,39,214,.04)}
.tb-gem{width:22px;height:22px;flex-shrink:0}.tb-gem svg{width:100%;height:100%}
.tb-name{font-size:15px;font-weight:700;letter-spacing:-.3px}
.tb-name sup{font-size:9px;color:var(--p);vertical-align:super}
/* Merged top navigation */
.tb-nav{flex:1;display:flex;align-items:center;padding:0 8px;gap:1px;height:100%;overflow:visible}
.tb-nav-item{position:relative;height:100%;display:flex;align-items:center}
.tb-nav-btn{display:flex;align-items:center;gap:5px;height:100%;padding:0 12px;border:none;border-bottom:2px solid transparent;background:transparent;font:inherit;font-size:13px;font-weight:500;color:var(--mu);cursor:pointer;transition:all .15s;white-space:nowrap;position:relative}
.tb-nav-btn .ms{font-size:15px;font-variation-settings:'FILL' 0}
.tb-nav-btn:hover{color:var(--tx)}
.tb-nav-btn.on{color:var(--p);font-weight:600;border-bottom-color:var(--p)}
.tb-nav-btn.on .ms{font-variation-settings:'FILL' 1;color:var(--p)}
.tb-nav-btn .arr{font-family:'Material Symbols Rounded';font-size:12px;color:var(--mu2);margin-left:1px;font-variation-settings:'FILL' 0;transition:transform .18s ease}
.tb-nav-item.dd-open .arr{transform:rotate(180deg)}
/* Section color accents */
.tb-nav-btn[data-s="知识宇宙"].on{color:var(--cl);border-bottom-color:var(--cl)}
.tb-nav-btn[data-s="学习中心"].on{color:var(--cg);border-bottom-color:var(--cg)}
.tb-nav-btn[data-s="错题归因"].on{color:var(--cr);border-bottom-color:var(--cr)}
.tb-nav-btn[data-s="成长洞察"].on{color:var(--ca);border-bottom-color:var(--ca)}
.tb-nav-btn[data-s="家长端"].on{color:var(--cpr);border-bottom-color:var(--cpr)}
/* Dropdown panel — smooth fade + slide */
.tb-dropdown{
  position:absolute;top:100%;left:0;min-width:185px;
  background:var(--sf);border:1px solid var(--brd);border-radius:12px;
  box-shadow:0 8px 32px rgba(0,0,0,.13),0 2px 8px rgba(0,0,0,.06);
  padding:4px 4px 5px;z-index:300;
  opacity:0;visibility:hidden;
  transform:translateY(6px) scale(.98);
  transform-origin:top left;
  transition:opacity .18s ease,transform .18s ease,visibility .18s;
  pointer-events:none;
}
/* Invisible bridge fills gap between button and dropdown */
.tb-dropdown::before{content:'';position:absolute;top:-8px;left:0;right:0;height:8px;background:transparent}
.tb-dropdown.open{opacity:1;visibility:visible;transform:translateY(0) scale(1);pointer-events:all}
.tb-dd-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border:none;border-radius:7px;background:transparent;width:100%;text-align:left;font:inherit;font-size:12.5px;color:var(--mu);cursor:pointer;transition:all .1s;white-space:nowrap}
.tb-dd-item:hover{background:var(--pd);color:var(--p)}
.tb-dd-item.on{background:var(--pd);color:var(--p);font-weight:600}
.tb-dd-item .ms{font-size:14px;width:16px;text-align:center;flex-shrink:0;font-variation-settings:'FILL' 0}
.tb-dd-item.on .ms{font-variation-settings:'FILL' 1}
.tb-dd-sep{height:1px;background:var(--brd);margin:4px 8px}
.stag{font-size:9px;font-weight:800;padding:1px 5px;border-radius:8px;letter-spacing:.02em}
.stag.ai{background:rgba(108,39,214,.12);color:var(--p)}
.stag.hot{background:rgba(220,38,38,.1);color:#dc2626}
.tb-right{display:flex;align-items:center;gap:4px;padding:0 12px;flex-shrink:0;border-left:1px solid var(--brd)}
.ai-pill{display:flex;align-items:center;gap:5px;padding:3px 9px;margin-right:4px;background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.18);border-radius:20px;font-size:10.5px;font-weight:600;color:#059669}
.ai-dot{width:5px;height:5px;border-radius:50%;background:#10b981;box-shadow:0 0 5px #10b981;animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.35}}
.ibtn{width:30px;height:30px;border:none;border-radius:7px;background:transparent;color:var(--mu);display:flex;align-items:center;justify-content:center;font-family:'Material Symbols Rounded';font-size:16px;font-variation-settings:'FILL' 0;transition:all .12s}
.ibtn:hover{background:var(--pd);color:var(--p)}
.uc{display:none;align-items:center;gap:6px;padding:3px 10px 3px 5px;border:1px solid var(--brd);border-radius:20px;cursor:pointer;transition:all .12s}
.uc:hover{border-color:var(--p);background:var(--pd)}
.uc-av{width:20px;height:20px;border-radius:5px;background:linear-gradient(135deg,var(--p),#a855f7);display:flex;align-items:center;justify-content:center;color:white;font-size:9px;font-weight:700}
.uc-name{font-size:11.5px;font-weight:600}.uc-xp{font-size:10px;color:var(--mu);border-left:1px solid var(--brd);padding-left:6px}
.appbody{flex:1;min-height:0;display:flex;overflow:hidden}
#sb{display:none}
.sbsc{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;padding:8px 6px}
.sbsc::-webkit-scrollbar{width:3px}.sbsc::-webkit-scrollbar-thumb{background:var(--pd);border-radius:3px}
/* Section group */
.sb-group{margin-bottom:3px}
.sb-group-hd{
  display:flex;align-items:center;gap:8px;
  padding:7px 9px;border-radius:8px;
  border:none;background:transparent;width:100%;text-align:left;
  font-size:11.5px;font-weight:700;color:var(--mu);cursor:pointer;
  transition:all .1s;
}
.sb-group-hd:hover{background:var(--bg);color:var(--tx)}
.sb-group-hd.on{color:var(--p);background:var(--pd)}
.sb-group-hd .ms{font-size:15px;flex-shrink:0;font-variation-settings:'FILL' 0}
.sb-group-hd.on .ms{font-variation-settings:'FILL' 1}
.sb-group-hd .sg-label{flex:1}
.sb-group-hd .sg-arr{font-family:'Material Symbols Rounded';font-size:13px;color:var(--mu2);margin-left:auto;transition:transform .2s;font-variation-settings:'FILL' 0}
.sb-group-hd.on .sg-arr{transform:rotate(90deg);color:var(--p)}
/* Color variants per section */
.sb-group-hd[data-s="知识宇宙"].on{color:var(--cl);background:rgba(37,99,235,.07)}
.sb-group-hd[data-s="学习中心"].on{color:var(--cg);background:rgba(5,150,105,.07)}
.sb-group-hd[data-s="错题归因"].on{color:var(--cr);background:rgba(220,38,38,.07)}
.sb-group-hd[data-s="成长洞察"].on{color:var(--ca);background:rgba(217,119,6,.07)}
.sb-group-hd[data-s="家长端"].on{color:var(--cpr);background:rgba(124,58,237,.07)}
.sb-group-hd[data-s="知识宇宙"].on .ms,.sb-group-hd[data-s="知识宇宙"].on .sg-arr{color:var(--cl)}
.sb-group-hd[data-s="学习中心"].on .ms,.sb-group-hd[data-s="学习中心"].on .sg-arr{color:var(--cg)}
.sb-group-hd[data-s="错题归因"].on .ms,.sb-group-hd[data-s="错题归因"].on .sg-arr{color:var(--cr)}
.sb-group-hd[data-s="成长洞察"].on .ms,.sb-group-hd[data-s="成长洞察"].on .sg-arr{color:var(--ca)}
.sb-group-hd[data-s="家长端"].on .ms,.sb-group-hd[data-s="家长端"].on .sg-arr{color:var(--cpr)}
/* Sub items */
.sb-items{padding-left:10px;overflow:hidden;max-height:0;transition:max-height .22s ease}
.sb-items.open{max-height:500px}
.sbi{display:flex;align-items:center;gap:7px;padding:5px 8px;border:none;border-radius:6px;background:transparent;width:100%;text-align:left;font-size:12px;font-weight:500;color:var(--mu);transition:all .1s;white-space:nowrap;overflow:hidden}
.sbi span:nth-child(2){overflow:hidden;text-overflow:ellipsis;min-width:0;flex:1}
.sbi:hover{background:var(--bg);color:var(--tx)}
.sbi.on{background:var(--pd);color:var(--p);font-weight:600}
.sbi .ms{font-size:13px;flex-shrink:0;width:16px;text-align:center;font-variation-settings:'FILL' 0}
.sbi.on .ms{font-variation-settings:'FILL' 1}
.sbi.on[data-s="知识宇宙"]{background:rgba(37,99,235,.08);color:var(--cl)}
.sbi.on[data-s="学习中心"]{background:rgba(5,150,105,.08);color:var(--cg)}
.sbi.on[data-s="错题归因"]{background:rgba(220,38,38,.08);color:var(--cr)}
.sbi.on[data-s="成长洞察"]{background:rgba(217,119,6,.08);color:var(--ca)}
.sbi.on[data-s="家长端"]{background:rgba(124,58,237,.08);color:var(--cpr)}
.stag{margin-left:auto;flex-shrink:0;font-size:8.5px;font-weight:700;padding:1px 5px;border-radius:4px}
.stag.ai{background:var(--pd);color:var(--p)}.stag.hot{background:rgba(220,38,38,.1);color:#dc2626}
.sdiv{height:1px;background:var(--brd);margin:6px 4px}
.sb-ft{flex-shrink:0;padding:8px;border-top:1px solid var(--brd)}
.sb-urow{display:flex;align-items:center;gap:8px;padding:6px 7px;border-radius:8px;cursor:pointer;transition:background .12s}
.sb-urow:hover{background:var(--bg)}
.sb-uav{width:26px;height:26px;border-radius:7px;background:linear-gradient(135deg,var(--p),#a855f7);display:flex;align-items:center;justify-content:center;color:white;font-size:9px;font-weight:700;flex-shrink:0}
.sb-un{font-size:11.5px;font-weight:600}.sb-us{font-size:10px;color:var(--mu2)}
.coc{flex:1;min-width:0;display:flex;flex-direction:column;overflow:hidden}
.ctx{height:33px;flex-shrink:0;background:var(--sf);border-bottom:1px solid var(--brd);display:none;align-items:center;padding:0 18px;gap:5px}
.bc{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--mu)}
.bci{cursor:pointer;transition:color .1s}.bci:hover{color:var(--tx)}.bci.cur{color:var(--tx);font-weight:600}.bsep{opacity:.3}
.cpill{margin-left:auto;font-size:10px;font-weight:700;padding:2px 8px;border-radius:5px;display:none}
.lstrip{height:30px;flex-shrink:0;background:var(--bg);border-bottom:1px solid var(--brd);display:none;align-items:center;padding:0 10px;gap:1px;overflow-x:auto}
.lstrip::-webkit-scrollbar{display:none}
.line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.lsbt{display:flex;align-items:center;gap:4px;padding:3px 9px;border:none;border-radius:5px;background:transparent;font:inherit;font-size:10.5px;font-weight:500;color:var(--mu2);white-space:nowrap;flex-shrink:0;transition:all .1s}
.lsbt:hover{background:rgba(255,255,255,.7);color:var(--mu)}.lsbt.on{background:white;color:var(--p);font-weight:700;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.lsbt .ms{font-size:11px}.lsnum{width:13px;height:13px;border-radius:50%;background:var(--brd);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:var(--mu2)}
.lsbt.on .lsnum{background:var(--pd);color:var(--p)}.lsarr{font-family:'Material Symbols Rounded';font-size:10px;color:var(--mu2);opacity:.35;flex-shrink:0}
.farea{flex:1;min-height:0;position:relative;overflow:hidden;background:white}
.pf{position:absolute;inset:0;width:100%;height:100%;border:none;display:none;background:white}
.pf.on{display:block}
.lbar{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--p),#a855f7,#06b6d4,var(--p));background-size:200% 100%;animation:lba 1s linear infinite;z-index:9;display:none}
.lbar.on{display:block}@keyframes lba{0%{background-position:0%}100%{background-position:200%}}
/* ── AI 悬浮助手 ───────────────────────── */
#ai-fab{
  position:fixed;bottom:28px;right:28px;z-index:8000;
  width:48px;height:48px;border-radius:50%;
  background:linear-gradient(135deg,var(--p),#a855f7);
  border:none;box-shadow:0 4px 20px var(--pg);
  display:none;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;
  font-family:'Material Symbols Rounded';font-size:22px;
  font-variation-settings:'FILL' 1;color:white;
}
#ai-fab.show{display:flex}
#ai-fab:hover{transform:scale(1.1);box-shadow:0 6px 28px var(--pg)}
#ai-fab .ai-fab-dot{
  position:absolute;top:2px;right:2px;width:10px;height:10px;
  border-radius:50%;background:#10b981;border:2px solid white;
  animation:blink 2s ease-in-out infinite;
}
#ai-panel{
  position:fixed;bottom:86px;right:28px;z-index:8000;
  width:360px;max-height:520px;
  background:var(--sf);border:1px solid var(--brd);
  border-radius:18px;box-shadow:0 12px 48px rgba(0,0,0,.15);
  display:none;flex-direction:column;overflow:hidden;
  animation:panelIn .2s ease;
}
#ai-panel.show{display:flex}
@keyframes panelIn{from{opacity:0;transform:translateY(12px) scale(.97)}to{opacity:1;transform:none}}
.aip-head{
  display:flex;align-items:center;gap:10px;
  padding:14px 16px;border-bottom:1px solid var(--brd);flex-shrink:0;
}
.aip-gem{width:28px;height:28px;border-radius:8px;
  background:linear-gradient(135deg,var(--p),#a855f7);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.aip-gem svg{width:14px;height:14px;fill:white}
.aip-title{font-size:13.5px;font-weight:700;flex:1}
.aip-status{font-size:10px;color:var(--cg);font-weight:600}
.aip-close{width:26px;height:26px;border:none;border-radius:6px;background:transparent;
  color:var(--mu);font-family:'Material Symbols Rounded';font-size:16px;
  font-variation-settings:'FILL' 0;cursor:pointer;transition:all .12s}
.aip-close:hover{background:var(--bg);color:var(--tx)}
.aip-msgs{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px;min-height:0}
.aip-msgs::-webkit-scrollbar{width:3px}
.aip-msgs::-webkit-scrollbar-thumb{background:var(--pd);border-radius:3px}
.aip-msg{max-width:88%;font-size:13px;line-height:1.6;padding:10px 13px;border-radius:12px;word-break:break-word}
.aip-msg.ai{background:var(--bg);color:var(--tx);border-radius:4px 12px 12px 12px;align-self:flex-start}
.aip-msg.user{background:var(--p);color:white;border-radius:12px 4px 12px 12px;align-self:flex-end}
.aip-msg.typing{opacity:.6}
.aip-typing-dots span{display:inline-block;width:6px;height:6px;border-radius:50%;
  background:var(--mu);margin:0 2px;animation:tdot .9s ease-in-out infinite}
.aip-typing-dots span:nth-child(2){animation-delay:.2s}
.aip-typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes tdot{0%,80%,100%{transform:scale(.8);opacity:.4}40%{transform:scale(1.2);opacity:1}}
.aip-shortcuts{
  display:flex;flex-wrap:wrap;gap:5px;padding:8px 12px;
  border-top:1px solid var(--brd);flex-shrink:0;
}
