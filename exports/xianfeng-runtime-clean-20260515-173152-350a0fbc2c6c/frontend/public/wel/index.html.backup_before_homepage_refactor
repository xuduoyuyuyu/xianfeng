              html += `<div class="knowledge-group-header px-6 py-2.5 flex items-center gap-2"><span class="material-symbols-outlined text-primary text-lg">folder_open</span><h4 class="text-sm font-bold text-slate-800">${esc(k)} <span class="text-xs font-normal text-primary/60 ml-1">(${rows.length})</span>${headerBind ? `<span class="ml-2 text-[10px] font-normal text-slate-500">${headerBind}</span>` : ''}</h4></div>`;
